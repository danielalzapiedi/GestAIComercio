@inherits LayoutComponentBase
@inject JwtAuthStateProvider Auth
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <header id="header" class="header fixed-top d-flex align-items-center">
            <div class="d-flex align-items-center justify-content-between w-100 px-3">
                <a href="/dashboard" class="logo d-flex align-items-center text-decoration-none">
                    <span class="d-none d-lg-block">SaaS Starter Kit</span>
                </a>
                <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">Salir</button>
            </div>
        </header>

        <aside id="sidebar" class="sidebar">
            <ul class="sidebar-nav" id="sidebar-nav">
                <li class="nav-item"><NavLink class="nav-link" href="/dashboard"><i class="bi bi-grid"></i><span>Dashboard</span></NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/users"><i class="bi bi-people"></i><span>Users</span></NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/account"><i class="bi bi-building"></i><span>Account</span></NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/plans"><i class="bi bi-card-checklist"></i><span>Plans</span></NavLink></li>
                <li class="nav-item"><NavLink class="nav-link" href="/audit-log"><i class="bi bi-journal-text"></i><span>Audit Log</span></NavLink></li>
            </ul>
        </aside>

        <main id="main" class="main">
            @Body
        </main>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task Logout()
    {
        await Auth.SetTokenAsync(null);
        Navigation.NavigateTo("/login", true);
    }
}
