@inherits LayoutComponentBase
@implements IDisposable
@using GestAI.Web.Dtos
@inject JwtAuthStateProvider Auth
@inject NavigationManager Navigation
@inject ApiClient Api
@inject GestAI.Web.Service.AppState AppState

<AuthorizeView>
    <Authorized>
        <div class="ui-app-shell">
            <header id="header" class="header fixed-top d-flex align-items-center ui-topbar">
                <div class="d-flex align-items-center justify-content-between w-100 px-3 px-lg-4 gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn ui-nav-toggle d-xl-none" type="button" @onclick="ToggleSidebar" aria-label="Abrir o cerrar menú principal" aria-expanded="@_sidebarOpen">
                            <i class="bi @(_sidebarOpen ? "bi-x-lg" : "bi-list")"></i>
                        </button>
                        <a href="/dashboard" class="logo d-flex align-items-center text-decoration-none gap-3">
                            <span class="ui-brand-mark"><i class="bi bi-shop-window"></i></span>
                            <span class="ui-brand-title">AiCommerce</span>
                        </a>
                    </div>
                    <div class="d-flex align-items-center gap-2 gap-lg-3">
                        @if (_loadingAccess)
                        {
                            <span class="text-muted small">Cargando acceso...</span>
                        }
                        else if (_access is not null)
                        {
                            <div class="dropdown">
                                <button class="btn ui-user-menu dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="ui-avatar">@UserInitial</span>
                                    <span class="text-start d-none d-md-block">
                                        <span class="d-block ui-user-eyebrow">Sesión activa</span>
                                        <span class="d-block ui-user-name">@UserDisplayName</span>
                                    </span>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end ui-user-dropdown">
                                    <div class="ui-user-dropdown-head">
                                        <div class="ui-avatar ui-avatar-lg">@UserInitial</div>
                                        <div>
                                            <div class="ui-user-dropdown-title">@UserDisplayName</div>
                                            <div class="ui-user-dropdown-subtitle">@UserRoleLabel</div>
                                        </div>
                                    </div>

                                    @if (CanAccess(SaasModule.Configuration))
                                    {
                                        <a class="dropdown-item" href="/account"><i class="bi bi-person-circle"></i><span>Mi cuenta</span></a>
                                    }
                                    @if (CanAccess(SaasModule.Plans))
                                    {
                                        <a class="dropdown-item" href="/plans"><i class="bi bi-stars"></i><span>Mi plan</span></a>
                                    }
                                    @if (CanAccess(SaasModule.Users))
                                    {
                                        <a class="dropdown-item" href="/users"><i class="bi bi-people"></i><span>Usuarios</span></a>
                                    }

                                    <div class="dropdown-divider"></div>
                                    <button class="dropdown-item text-danger" @onclick="Logout">
                                        <i class="bi bi-box-arrow-right"></i>
                                        <span>Cerrar sesión</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </header>

            <button class="ui-sidebar-backdrop @(_sidebarOpen ? "is-visible" : null)" type="button" @onclick="CloseSidebar" aria-label="Cerrar menú"></button>

            <aside id="sidebar" class="sidebar ui-sidebar @(_sidebarOpen ? "is-open" : null)">
                <div class="ui-sidebar-head ui-sidebar-head-compact">
                    <div>
                        <div class="ui-sidebar-title">Menú principal</div>
                        <div class="ui-sidebar-subtitle">Accesos disponibles</div>
                    </div>
                    @if (_access is not null)
                    {
                        <span class="ui-sidebar-role-pill">@UserRoleLabel</span>
                    }
                </div>

                <ul class="sidebar-nav ui-nav-list" id="sidebar-nav">
                    @if (CanAccess(SaasModule.Dashboard))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/dashboard" @onclick="CloseSidebar"><i class="bi bi-grid"></i><span>Dashboard</span></NavLink></li>
                    }

                    @if (_access?.IsPlatformAdmin == true)
                    {
                        <li class="nav-heading">Plataforma</li>
                        <li class="nav-item"><NavLink class="nav-link" href="/platform/tenants" @onclick="CloseSidebar"><i class="bi bi-building-gear"></i><span>Tenants</span></NavLink></li>
                    }

                    <li class="nav-heading">Operación diaria</li>
                    @if (CanAccess(SaasModule.Customers))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/customers" @onclick="CloseSidebar"><i class="bi bi-person-vcard"></i><span>Clientes</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Quotes))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/quotes" @onclick="CloseSidebar"><i class="bi bi-file-earmark-text"></i><span>Presupuestos</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Sales))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/sales" @onclick="CloseSidebar"><i class="bi bi-receipt-cutoff"></i><span>Ventas</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/invoices" @onclick="CloseSidebar"><i class="bi bi-file-earmark-medical"></i><span>Facturación</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/delivery-notes" @onclick="CloseSidebar"><i class="bi bi-truck-flatbed"></i><span>Remitos</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/reports" @onclick="CloseSidebar"><i class="bi bi-bar-chart-line"></i><span>Reportes</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Purchases))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/purchases" @onclick="CloseSidebar"><i class="bi bi-bag-check"></i><span>Compras</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Cash))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/cash" @onclick="CloseSidebar"><i class="bi bi-cash-stack"></i><span>Caja</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/customer-current-accounts" @onclick="CloseSidebar"><i class="bi bi-person-lines-fill"></i><span>Ctas. clientes</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/supplier-current-accounts" @onclick="CloseSidebar"><i class="bi bi-journal-richtext"></i><span>Ctas. proveedores</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Products))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/inventory" @onclick="CloseSidebar"><i class="bi bi-boxes"></i><span>Inventario</span></NavLink></li>
                    }

                    <li class="nav-heading">Catálogo y stock</li>
                    @if (CanAccess(SaasModule.Categories))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/categories" @onclick="CloseSidebar"><i class="bi bi-diagram-3"></i><span>Categorías</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Products))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/products" @onclick="CloseSidebar"><i class="bi bi-box"></i><span>Productos</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/price-lists" @onclick="CloseSidebar"><i class="bi bi-tags"></i><span>Listas de precios</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/products/import" @onclick="CloseSidebar"><i class="bi bi-upload"></i><span>Importación</span></NavLink></li>
                    }

                    <li class="nav-heading">Administración</li>
                    @if (CanAccess(SaasModule.Branches))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/branches" @onclick="CloseSidebar"><i class="bi bi-shop"></i><span>Sucursales</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Warehouses))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/warehouses" @onclick="CloseSidebar"><i class="bi bi-box-seam"></i><span>Depósitos</span></NavLink></li>
                    }
                    @if (CanAccess(SaasModule.Suppliers))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/suppliers" @onclick="CloseSidebar"><i class="bi bi-truck"></i><span>Proveedores</span></NavLink></li>
                    }

                    <li class="nav-heading">Configuración</li>
                    @if (CanAccess(SaasModule.AuditLog))
                    {
                        <li class="nav-item"><NavLink class="nav-link" href="/audit-log" @onclick="CloseSidebar"><i class="bi bi-journal-text"></i><span>Auditoría</span></NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/document-history" @onclick="CloseSidebar"><i class="bi bi-clock-history"></i><span>Historial</span></NavLink></li>
                    }
                </ul>
            </aside>

            <main id="main" class="main ui-main">
                <div class="ui-page-shell">
                    @Body
                </div>
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private CurrentUserAccessDto? _access;
    private bool _loadingAccess = true;
    private bool _sidebarOpen;
    private string UserRoleLabel => _access?.IsPlatformAdmin == true ? "Super Admin" : _access?.Role?.ToString() ?? "Usuario";
    private string UserDisplayName => _access?.IsPlatformAdmin == true ? "Administrador de plataforma" : _access?.Role == InternalUserRole.Owner ? "Owner del tenant" : _access?.Role == InternalUserRole.Employee ? "Usuario del tenant" : "Mi cuenta";
    private string UserInitial => string.IsNullOrWhiteSpace(UserDisplayName) ? "A" : UserDisplayName.Trim()[0].ToString().ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        await LoadAccess();
    }

    private async Task LoadAccess()
    {
        _loadingAccess = true;
        try
        {
            var result = await Api.GetAsync<AppResult<CurrentUserAccessDto>>("api/saas/me/access");
            _access = result?.Data;
            if (_access is not null)
            {
                AppState.SetAccess(_access);
            }
        }
        finally
        {
            _loadingAccess = false;
        }
    }

    private bool CanAccess(SaasModule module) => AppState.CanAccess(module);

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    private void CloseSidebar() => _sidebarOpen = false;

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_sidebarOpen)
        {
            _sidebarOpen = false;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task Logout()
    {
        _sidebarOpen = false;
        await Auth.SetTokenAsync(null);
        Navigation.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
