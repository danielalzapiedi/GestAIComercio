@page "/users"
@using Microsoft.AspNetCore.Components.Routing
@using GestAI.Web.Dtos
@using GestAI.Web.Security
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Usuarios</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Usuarios</div>
        <div class="page-hero-subtitle">Administrá accesos, roles y módulos disponibles para cada usuario del tenant.</div>
    </div>
    <div class="page-hero-meta">
        @if (_showForm)
        {
            <button class="btn btn-outline-secondary" @onclick="Cancel"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <span class="page-hero-chip"><i class="bi bi-people"></i> @_items.Count usuarios</span>
            <button class="btn btn-primary" @onclick="NewUser"><i class="bi bi-plus-circle me-2"></i>Nuevo usuario</button>
        }
    </div>
</section>

@if (!_loaded)
{
    <div class="card"><div class="card-body">Cargando usuarios...</div></div>
}
else if (_items.Count == 0)
{
    <EmptyState Title="Todavía no hay usuarios cargados"
                Description="Creá usuarios y definí los módulos a los que puede acceder cada empleado."
                Icon="bi-people">
        <button class="btn btn-primary" @onclick="NewUser">Crear primer usuario</button>
    </EmptyState>
}
else
{
    <NavigationLock ConfirmExternalNavigation="@(_showForm && _isDirty)" OnBeforeInternalNavigation="@ConfirmInternalNavigation" />
    <div class="ui-split-layout">
        <div class="card ui-data-card @(_showForm ? "d-none" : string.Empty)">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Accesos del tenant</div>
                        <h5 class="ui-card-title">Equipo del tenant</h5>
                        <div class="ui-card-subtitle">Roles, estado y permisos asignados por módulo.</div>
                    </div>
                </div>
                <div class="table-responsive">
                <table class="table table-striped">
                    <thead><tr><th>Nombre</th><th>Email</th><th>Rol</th><th>Módulos</th><th>Activo</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var u in _items)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@u.DisplayName</div>
                                <div class="ui-table-meta">ID: @u.UserId</div>
                            </td>
                            <td>@u.Email</td>
                            <td><StatusBadge Text="@u.Role.ToString()" /></td>
                            <td>@FormatModules(u)</td>
                            <td><StatusBadge IsActive="@u.IsActive" /></td>
                            <td>
                                <div class="ui-inline-actions">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(u)">Editar</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(u)">@(u.IsActive ? "Desactivar" : "Activar")</button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
                </div>
            </div>
        </div>

        <div class="card ui-form-card @(_showForm ? "w-100" : string.Empty)">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Editor</div>
                        <h5 class="ui-card-title">@(_showForm ? (_form.UserId is null ? "Nuevo usuario" : "Editar usuario") : "Alta y edición")</h5>
                        <div class="ui-card-subtitle">Definí datos personales, rol y accesos.</div>
                    </div>
                </div>

                @if (!_showForm)
                {
                    <EmptyState Title="Seleccioná una acción"
                                Description="Podés crear un usuario nuevo o editar uno existente desde la lista."
                                Icon="bi-person-plus">
                        <button class="btn btn-primary" @onclick="NewUser">Nuevo usuario</button>
                    </EmptyState>
                }
                else
                {
                    <FormFeedback Error="@_error" Success="@_success" />
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Nombre</label><input class="form-control" placeholder="Nombre" @bind="_form.Nombre" @bind:after="MarkDirty" /></div>
                        <div class="col-md-6"><label class="form-label">Apellido</label><input class="form-control" placeholder="Apellido" @bind="_form.Apellido" @bind:after="MarkDirty" /></div>
                        <div class="col-12"><label class="form-label">Email</label><input class="form-control" placeholder="Email" @bind="_form.Email" @bind:after="MarkDirty" /></div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Rol</label>
                            <select class="form-select" value="@_form.Role" @onchange="OnRoleChanged">
                                @foreach (var role in Enum.GetValues<InternalUserRole>())
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password temporal</label>
                            <input class="form-control" placeholder="Solo para altas nuevas" @bind="_form.Password" @bind:after="MarkDirty" disabled="@(_form.UserId is not null)" />
                            @if (string.IsNullOrWhiteSpace(_form.UserId))
                            {
                                <div class="form-text">Se genera automáticamente una contraseña temporal segura. Compartila por un canal seguro.</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label d-block">Estado</label>
                            <div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" @bind:after="MarkDirty" /><span>@(_form.IsActive ? "Usuario activo" : "Usuario inactivo")</span></div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">Permisos por módulo</label>
                        @if (_form.Role == InternalUserRole.Owner)
                        {
                            <div class="alert alert-info py-2 mb-0">
                                El rol Owner tiene acceso completo a los módulos del tenant.
                            </div>
                        }
                        else
                        {
                            <div class="ui-check-grid">
                                @foreach (var module in _tenantModules)
                                {
                                    <label class="ui-check-card">
                                        <input type="checkbox" checked="@_form.AllowedModules.Contains(module)" @onchange="e => ToggleModule(module, e.Value)" />
                                        <span>@GetModuleLabel(module)</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="ui-action-bar">
                        <div class="ui-inline-actions">
                            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                            <button class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button>
                        </div>
                        <div class="ui-table-meta">Tip: usá permisos mínimos para cada empleado.</div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool _showForm;
    private bool _saving;
    private bool _isDirty;
    private List<AccountUserListItemDto> _items = new();
    private UpsertAccountUserCommand _form = new();
    private string? _error;
    private string? _success;
    private static readonly List<SaasModule> _tenantModules = Enum.GetValues<SaasModule>().Where(x => x != SaasModule.PlatformTenants).ToList();
    private static readonly List<SaasModule> _defaultEmployeeModules = new()
    {
        SaasModule.Dashboard,
        SaasModule.Branches,
        SaasModule.Warehouses,
        SaasModule.Categories,
        SaasModule.Products,
        SaasModule.Customers,
        SaasModule.Suppliers
    };

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _items = (await Api.GetAsync<AppResult<List<AccountUserListItemDto>>>("api/saas/users"))?.Data ?? new();
        _loaded = true;
    }

    private void NewUser()
    {
        _error = null;
        _success = null;
        _form = new UpsertAccountUserCommand
        {
            IsActive = true,
            Role = InternalUserRole.Employee,
            AllowedModules = _defaultEmployeeModules.ToList(),
            Password = GenerateTemporaryPassword()
        };
        _showForm = true;
        _isDirty = false;
    }

    private void Edit(AccountUserListItemDto u)
    {
        _error = null;
        _success = null;
        var parts = (u.DisplayName ?? string.Empty).Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
        _form = new UpsertAccountUserCommand
        {
            UserId = u.UserId,
            Nombre = parts.Length > 0 ? parts[0] : string.Empty,
            Apellido = parts.Length > 1 ? parts[1] : string.Empty,
            Email = u.Email,
            IsActive = u.IsActive,
            Role = u.Role,
            AllowedModules = u.AllowedModules.ToList()
        };
        _showForm = true;
        _isDirty = false;
    }

    private async Task Save()
    {
        _error = ValidateForm();
        _success = null;
        if (!string.IsNullOrWhiteSpace(_error))
            return;

        _saving = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_form.UserId))
            {
                await Api.PostAsync("api/saas/users", _form);
                _success = "Usuario creado correctamente. Compartí las credenciales temporales por un canal seguro.";
            }
            else
            {
                await Api.PutAsync($"api/saas/users/{_form.UserId}", _form);
                _success = "Usuario actualizado correctamente.";
            }

            _showForm = false;
            _isDirty = false;
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(AccountUserListItemDto u)
    {
        _error = null;
        _success = null;
        try
        {
            await Api.PostAsync($"api/saas/users/{u.UserId}/status", new { isActive = !u.IsActive });
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private void OnRoleChanged(ChangeEventArgs args)
    {
        if (!Enum.TryParse<InternalUserRole>(args.Value?.ToString(), out var role))
            return;

        _form.Role = role;
        _form.AllowedModules = role == InternalUserRole.Owner
            ? _tenantModules.ToList()
            : (_form.AllowedModules.Count > 0 ? _form.AllowedModules.Where(x => x != SaasModule.PlatformTenants).Distinct().ToList() : _defaultEmployeeModules.ToList());
        _isDirty = true;
    }

    private void ToggleModule(SaasModule module, object? value)
    {
        var isChecked = value is bool flag ? flag : bool.TryParse(value?.ToString(), out var parsed) && parsed;
        if (isChecked == true)
        {
            if (!_form.AllowedModules.Contains(module))
                _form.AllowedModules.Add(module);
        }
        else
        {
            _form.AllowedModules.Remove(module);
        }

        _isDirty = true;
    }

    private void Cancel()
    {
        _showForm = false;
        _isDirty = false;
        _error = null;
    }

    private string? ValidateForm()
    {
        if (string.IsNullOrWhiteSpace(_form.Nombre) || string.IsNullOrWhiteSpace(_form.Apellido))
            return "Completá nombre y apellido.";
        if (string.IsNullOrWhiteSpace(_form.Email) || !_form.Email.Contains('@'))
            return "Ingresá un email válido.";
        if (string.IsNullOrWhiteSpace(_form.UserId) && (string.IsNullOrWhiteSpace(_form.Password) || _form.Password.Length < 8))
            return "La contraseña temporal debe tener al menos 8 caracteres.";
        if (_form.Role == InternalUserRole.Employee && _form.AllowedModules.Count == 0)
            return "Asigná al menos un módulo para usuarios con rol Empleado.";
        return null;
    }

    private static string GenerateTemporaryPassword()
    {
        return PasswordGenerator.GenerateTemporaryPassword();
    }

    private static string GetModuleLabel(SaasModule module) => module switch
    {
        SaasModule.Dashboard => "Dashboard",
        SaasModule.Users => "Usuarios",
        SaasModule.Configuration => "Configuración",
        SaasModule.AuditLog => "Auditoría",
        SaasModule.Plans => "Plan",
        SaasModule.Branches => "Sucursales",
        SaasModule.Warehouses => "Depósitos",
        SaasModule.Categories => "Categorías",
        SaasModule.Products => "Productos",
        SaasModule.Customers => "Clientes",
        SaasModule.Suppliers => "Proveedores",
        _ => module.ToString()
    };

    private static string FormatModules(AccountUserListItemDto user)
        => user.Role == InternalUserRole.Owner
            ? "Acceso completo"
            : string.Join(", ", user.AllowedModules.Select(GetModuleLabel));

    private void MarkDirty() => _isDirty = true;

    private async Task ConfirmInternalNavigation(LocationChangingContext context)
    {
        if (!_showForm || !_isDirty || _saving)
            return;

        var leave = await JS.InvokeAsync<bool>("confirm", "Tenés cambios sin guardar. ¿Querés salir igual?");
        if (!leave)
            context.PreventNavigation();
    }
}
