@page "/account"
@inject ApiClient Api
@using GestAI.Web.Dtos

<h1>Account Settings</h1>

@if (_summary is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="card"><div class="card-body">
        <div class="mb-2"><strong>Estado:</strong> @(_summary.IsActive ? "Activa" : "Inactiva")</div>
        <div class="mb-2"><strong>Creación:</strong> @_summary.CreatedAtUtc.ToLocalTime()</div>
        <div class="mb-2"><strong>Plan:</strong> @_summary.PlanName</div>
        <div class="mb-2"><strong>Límites:</strong> usuarios @_summary.MaxUsers, entidades @_summary.MaxUnits</div>
        <label>Nombre de cuenta</label>
        <input class="form-control" @bind="_name" />
        <button class="btn btn-primary mt-3" @onclick="Save">Guardar</button>
    </div></div>
}

@code {
    private AccountSummaryDto? _summary;
    private string _name = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _summary = (await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary"))?.Data;
        _name = _summary?.Name ?? string.Empty;
    }

    private async Task Save()
    {
        await Api.PutAsync("api/saas/account", new UpdateAccountCommand(_name, null));
        _summary = (await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary"))?.Data;
    }
}
