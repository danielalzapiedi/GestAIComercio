@page "/account"
@inject ApiClient Api
@using GestAI.Web.Dtos

<div class="pagetitle d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1>Cuenta</h1>
        <p class="text-muted mb-0">Administración general del plan, capacidad contratada y auditoría visible.</p>
    </div>
    <button class="btn btn-outline-primary" @onclick="LoadAsync"><i class="bi bi-arrow-repeat"></i> Actualizar</button>
</div>

@if (!_loaded)
{
    <EmptyState Title="Cargando cuenta" Description="Estamos trayendo el resumen y la auditoría reciente." Icon="bi-building" />
}
else if (_summary is null)
{
    <EmptyState Title="No se pudo cargar la cuenta" Description="Reintentá en unos segundos para ver el resumen y la auditoría." Icon="bi-exclamation-triangle" />
}
else
{
    <div class="row g-3 mb-1">
        <div class="col-12 col-xl-8">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Datos generales</h5>
                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-md-7">
                            <label class="form-label">Nombre de la cuenta</label>
                            <input class="form-control" @bind="_name" />
                        </div>
                        <div class="col-12 col-md-5 d-flex justify-content-md-end">
                            <button class="btn btn-primary" @onclick="Save"><i class="bi bi-check2"></i> Guardar cambios</button>
                        </div>
                    </div>

                    <div class="summary-pill-grid mt-4">
                        <div class="summary-pill"><div class="label">Plan</div><div class="value">@_summary.PlanName</div></div>
                        <div class="summary-pill"><div class="label">Estado</div><div class="value">@_summary.PlanStatus</div></div>
                        <div class="summary-pill"><div class="label">Alta</div><div class="value">@_summary.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</div></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Capacidad contratada</h5>
                    <div class="summary-pill-grid">
                        <div class="summary-pill"><div class="label">Hospedajes</div><div class="value">@_summary.CurrentProperties / @_summary.MaxProperties</div></div>
                        <div class="summary-pill"><div class="label">Unidades</div><div class="value">@_summary.CurrentUnits / @_summary.MaxUnits</div></div>
                        <div class="summary-pill"><div class="label">Usuarios</div><div class="value">@_summary.CurrentUsers / @_summary.MaxUsers</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body pt-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <h5 class="card-title mb-0">Hospedajes de la cuenta</h5>
                <span class="text-muted small">@_summary.Properties.Count hospedaje(s)</span>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>Hospedaje</th><th>Estado</th><th>Unidades</th></tr></thead>
                    <tbody>
                    @foreach (var p in _summary.Properties)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td><StatusBadge IsActive="@p.IsActive" /></td>
                            <td>@p.UnitsCount</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body pt-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="card-title mb-1">Auditoría</h5>
                    <div class="small text-muted">Filtrá por entidad, usuario o rango de fechas para revisar cambios recientes.</div>
                </div>
                <button class="btn btn-sm btn-outline-primary" @onclick="LoadAudit"><i class="bi bi-funnel"></i> Aplicar filtros</button>
            </div>

            <div class="audit-filter-grid mb-3">
                <div>
                    <label class="form-label">Entidad</label>
                    <select class="form-select" @bind="_auditEntityName">
                        <option value="">Todas</option>
                        @foreach (var entity in _availableEntities)
                        {
                            <option value="@entity">@TranslateEntity(entity)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Usuario</label>
                    <input class="form-control" @bind="_auditUserName" placeholder="Nombre o email" />
                </div>
                <div>
                    <label class="form-label">Desde</label>
                    <input class="form-control" type="date" value="@_auditFromStr" @onchange="OnAuditFromChanged" />
                </div>
                <div>
                    <label class="form-label">Hasta</label>
                    <input class="form-control" type="date" value="@_auditToStr" @onchange="OnAuditToChanged" />
                </div>
            </div>

            @if (!_audit.Any())
            {
                <EmptyState Title="Sin eventos para mostrar" Description="Probá ampliar el rango o quitar filtros para revisar más actividad." Icon="bi-clock-history" />
            }
            else
            {
                <div class="agenda-stack">
                @foreach (var item in _audit)
                {
                    <div class="audit-timeline-item">
                        <div class="small text-muted">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") · @(string.IsNullOrWhiteSpace(item.UserName) ? "Sistema" : item.UserName)</div>
                        <div class="fw-semibold">@TranslateEntity(item.EntityName) · @TranslateAction(item.Action)</div>
                        <div>@item.Summary</div>
                    </div>
                }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loaded;
    private AccountSummaryDto? _summary;
    private List<AccountAuditItemDto> _audit = new();
    private string _name = string.Empty;
    private int? _selectedPlanId;
    private string? _auditEntityName;
    private string? _auditUserName;
    private DateOnly? _auditFrom = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
    private DateOnly? _auditTo = DateOnly.FromDateTime(DateTime.Today);
    private string _auditFromStr => _auditFrom?.ToString("yyyy-MM-dd") ?? string.Empty;
    private string _auditToStr => _auditTo?.ToString("yyyy-MM-dd") ?? string.Empty;
    private readonly string[] _availableEntities = ["Booking", "Payment", "RatePlan", "Promotion", "AccountUser", "Property", "Unit", "Account"];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var summary = await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary");
        _summary = summary?.Data;
        _name = _summary?.Name ?? string.Empty;
        await LoadAudit();
        _loaded = true;
    }

    private async Task LoadAudit()
    {
        var query = $"api/saas/account/audit?take=40{BuildAuditQuery()}";
        var audit = await Api.GetAsync<AppResult<List<AccountAuditItemDto>>>(query);
        _audit = audit?.Data ?? new();
    }

    private string BuildAuditQuery()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_auditEntityName)) parts.Add($"entityName={Uri.EscapeDataString(_auditEntityName)}");
        if (!string.IsNullOrWhiteSpace(_auditUserName)) parts.Add($"userName={Uri.EscapeDataString(_auditUserName)}");
        if (_auditFrom.HasValue) parts.Add($"from={_auditFrom:yyyy-MM-dd}");
        if (_auditTo.HasValue) parts.Add($"to={_auditTo:yyyy-MM-dd}");
        return parts.Count == 0 ? string.Empty : "&" + string.Join("&", parts);
    }

    private async Task Save()
    {
        await Api.PutAsync("api/saas/account", new UpdateAccountCommand(_name, _selectedPlanId));
        await LoadAsync();
        Api.Toast("Cuenta actualizada correctamente.");
    }

    private void OnAuditFromChanged(ChangeEventArgs e)
        => _auditFrom = DateOnly.TryParse(e.Value?.ToString(), out var date) ? date : null;

    private void OnAuditToChanged(ChangeEventArgs e)
        => _auditTo = DateOnly.TryParse(e.Value?.ToString(), out var date) ? date : null;

    private static string TranslateEntity(string entity) => entity switch
    {
        "Booking" => "Reserva",
        "Payment" => "Pago",
        "RatePlan" => "Tarifa",
        "Promotion" => "Promoción",
        "AccountUser" => "Usuario",
        "Property" => "Hospedaje",
        "Unit" => "Unidad",
        "Account" => "Cuenta",
        _ => entity
    };

    private static string TranslateAction(string action) => action?.Trim().ToLowerInvariant() switch
    {
        "created" => "Creación",
        "updated" => "Actualización",
        "activated" => "Activación",
        "deactivated" => "Desactivación",
        _ => action
    };
}
