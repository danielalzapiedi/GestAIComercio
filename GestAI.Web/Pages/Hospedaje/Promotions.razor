@page "/promotions/{PropertyId:int}"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Promociones</PageTitle>

<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Promociones y reglas</h1>
        <p class="text-muted mb-0">Administrá descuentos, acumulación, prioridades y restricciones comerciales.</p>
    </div>
    <button class="btn btn-primary" @onclick="NewItem">Nueva promoción</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card"><div class="card-body pt-3">
            <div class="row g-2 mb-3">
                <div class="col-md-6"><input class="form-control" placeholder="Buscar por nombre" @bind="_search" /></div>
                <div class="col-md-3"><select class="form-select" @bind="_showDeleted"><option value="false">Activas/no borradas</option><option value="true">Incluir eliminadas</option></select></div>
                <div class="col-md-3"><button class="btn btn-outline-primary w-100" @onclick="Load">Actualizar</button></div>
            </div>
            @if (!_loaded)
            {
                <EmptyState Title="Cargando información" Description="Estamos trayendo los datos de esta pantalla." Icon="bi-hourglass-split" />
            }
            else if (!Filtered.Any())
            {
                <EmptyState Title="No hay promociones para mostrar" Description="Creá una promoción o ampliá los filtros para verla." Icon="bi-tags" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle table-sm">
                        <thead><tr><th>Nombre</th><th>Unidad</th><th>Valor</th><th>Prioridad</th><th>Estado</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var item in Filtered)
                        {
                            <tr>
                                <td><strong>@item.Name</strong><div class="small text-muted">@item.DateFrom.ToString("dd/MM/yyyy") - @item.DateTo.ToString("dd/MM/yyyy")</div></td>
                                <td>@(item.UnitName ?? "Toda la propiedad")</td>
                                <td>@item.Value @item.ValueType</td>
                                <td>@item.Priority</td>
                                <td>
                                    @if (item.IsDeleted)
                                    {<StatusBadge Text="Eliminada" CssClass="ui-badge ui-badge-neutral" />}
                                    else if (item.IsActive)
                                    {<StatusBadge Text="Activa" CssClass="ui-badge ui-badge-success" />}
                                    else
                                    {<StatusBadge Text="Inactiva" CssClass="ui-badge ui-badge-neutral" />}
                                </td>
                                <td class="text-end"><button class="btn btn-sm btn-outline-primary" @onclick="(()=>Edit(item))">Editar</button></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div></div>
    </div>
    <div class="col-lg-5">
        <div class="card"><div class="card-body pt-3">
            <h5 class="card-title">@(_editingId.HasValue ? "Editar promoción" : "Nueva promoción")</h5>
            <EditForm Model="this" OnValidSubmit="Save">
                <div class="row g-2">
                    <div class="col-md-12"><label class="form-label">Nombre</label><input class="form-control" @bind="Name" /></div>
                    <div class="col-md-12"><label class="form-label">Descripción</label><textarea class="form-control" rows="2" @bind="Description"></textarea></div>
                    <div class="col-md-6"><label class="form-label">Unidad</label><select class="form-select" @bind="UnitId"><option value="">Toda la propiedad</option>@foreach (var u in _units.Where(x=>x.IsActive)){<option value="@u.Id">@u.Name</option>}</select></div>
                    <div class="col-md-3"><label class="form-label">Activa</label><select class="form-select" @bind="IsActive"><option value="true">Sí</option><option value="false">No</option></select></div>
                    <div class="col-md-3"><label class="form-label">Acumulable</label><select class="form-select" @bind="IsCumulative"><option value="true">Sí</option><option value="false">No</option></select></div>
                    <div class="col-md-4"><label class="form-label">Tipo</label><select class="form-select" @bind="ValueType">@foreach (var t in Enum.GetValues<DiscountValueType>()){<option value="@t">@t</option>}</select></div>
                    <div class="col-md-4"><label class="form-label">Scope</label><select class="form-select" @bind="Scope">@foreach (var t in Enum.GetValues<PromotionScope>()){<option value="@t">@t</option>}</select></div>
                    <div class="col-md-4"><label class="form-label">Valor</label><input class="form-control" type="number" step="0.01" @bind="Value" /></div>
                    <div class="col-md-4"><label class="form-label">Prioridad</label><input class="form-control" type="number" @bind="Priority" /></div>
                    <div class="col-md-4"><label class="form-label">Desde</label><input class="form-control" type="date" @bind="DateFrom" /></div>
                    <div class="col-md-4"><label class="form-label">Hasta</label><input class="form-control" type="date" @bind="DateTo" /></div>
                    <div class="col-md-3"><label class="form-label">Min noches</label><input class="form-control" type="number" @bind="MinNights" /></div>
                    <div class="col-md-3"><label class="form-label">Max noches</label><input class="form-control" type="number" @bind="MaxNights" /></div>
                    <div class="col-md-3"><label class="form-label">Lead min</label><input class="form-control" type="number" @bind="BookingWindowDaysMin" /></div>
                    <div class="col-md-3"><label class="form-label">Lead max</label><input class="form-control" type="number" @bind="BookingWindowDaysMax" /></div>
                    <div class="col-md-6"><label class="form-label">Check-in permitido</label><input class="form-control" @bind="AllowedCheckInDays" placeholder="Monday,Friday" /></div>
                    <div class="col-md-6"><label class="form-label">Check-out permitido</label><input class="form-control" @bind="AllowedCheckOutDays" placeholder="Sunday" /></div>
                </div>
                <div class="d-flex justify-content-end gap-2 mt-3">
                    @if (_editingId.HasValue)
                    {
                        <button type="button" class="btn btn-outline-danger" @onclick="Delete">Eliminar lógica</button>
                    }
                    <button type="button" class="btn btn-light border" @onclick="NewItem">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </EditForm>
        </div></div>
    </div>
</div>

@code {
    [Parameter] public int PropertyId { get; set; }
    private List<PromotionDto> _items = new();
    private List<UnitListItemDto> _units = new();
    private string? _search;
    private bool _showDeleted;
    private bool _loaded;
    private string? _message;
    private bool _success;
    private int? _editingId;

    public int? UnitId { get; set; }
    public string Name { get; set; } = string.Empty;
    public string? Description { get; set; }
    public bool IsActive { get; set; } = true;
    public DiscountValueType ValueType { get; set; } = DiscountValueType.Percentage;
    public PromotionScope Scope { get; set; } = PromotionScope.EntireStay;
    public decimal Value { get; set; }
    public bool IsCumulative { get; set; }
    public int Priority { get; set; } = 100;
    public DateOnly DateFrom { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    public DateOnly DateTo { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddMonths(1));
    public int? MinNights { get; set; }
    public int? MaxNights { get; set; }
    public int? BookingWindowDaysMin { get; set; }
    public int? BookingWindowDaysMax { get; set; }
    public string? AllowedCheckInDays { get; set; }
    public string? AllowedCheckOutDays { get; set; }

    private IEnumerable<PromotionDto> Filtered => _items.Where(x => string.IsNullOrWhiteSpace(_search) || x.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        _units = (await Api.GetAsync<AppResult<List<UnitListItemDto>>>($"api/properties/{PropertyId}/units"))?.Data ?? new();
        await Load();
    }

    private async Task Load()
    {
        _loaded = false;
        _items = (await Api.GetAsync<AppResult<List<PromotionDto>>>($"api/properties/{PropertyId}/promotions?includeDeleted={_showDeleted}"))?.Data ?? new();
        _loaded = true;
    }

    private void NewItem()
    {
        _editingId = null;
        UnitId = null;
        Name = string.Empty;
        Description = null;
        IsActive = true;
        ValueType = DiscountValueType.Percentage;
        Scope = PromotionScope.EntireStay;
        Value = 0;
        IsCumulative = false;
        Priority = 100;
        DateFrom = DateOnly.FromDateTime(DateTime.Today);
        DateTo = DateOnly.FromDateTime(DateTime.Today.AddMonths(1));
        MinNights = MaxNights = BookingWindowDaysMin = BookingWindowDaysMax = null;
        AllowedCheckInDays = AllowedCheckOutDays = null;
    }

    private void Edit(PromotionDto item)
    {
        _editingId = item.Id;
        UnitId = item.UnitId;
        Name = item.Name;
        Description = item.Description;
        IsActive = item.IsActive;
        ValueType = item.ValueType;
        Scope = item.Scope;
        Value = item.Value;
        IsCumulative = item.IsCumulative;
        Priority = item.Priority;
        DateFrom = item.DateFrom;
        DateTo = item.DateTo;
        MinNights = item.MinNights;
        MaxNights = item.MaxNights;
        BookingWindowDaysMin = item.BookingWindowDaysMin;
        BookingWindowDaysMax = item.BookingWindowDaysMax;
        AllowedCheckInDays = item.AllowedCheckInDays;
        AllowedCheckOutDays = item.AllowedCheckOutDays;
    }

    private async Task Save()
    {
        var cmd = new UpsertPromotionCommand(PropertyId, _editingId, UnitId, Name, Description, IsActive, ValueType, Scope, Value, IsCumulative, Priority, DateFrom, DateTo, MinNights, MaxNights, BookingWindowDaysMin, BookingWindowDaysMax, AllowedCheckInDays, AllowedCheckOutDays);
        AppResult<int>? res = _editingId.HasValue
            ? await Api.PutAsync<UpsertPromotionCommand, AppResult<int>>($"api/properties/{PropertyId}/promotions/{_editingId.Value}", cmd)
            : await Api.PostAsync<UpsertPromotionCommand, AppResult<int>>($"api/properties/{PropertyId}/promotions", cmd);
        _success = res?.Success == true;
        _message = _success ? "Promoción guardada correctamente." : (res?.Message ?? "No se pudo guardar la promoción.");
        if (_success)
        {
            await Load();
            NewItem();
        }
    }

    private async Task Delete()
    {
        if (!_editingId.HasValue) return;
        var res = await Api.DeleteAsync<AppResult>($"api/properties/{PropertyId}/promotions/{_editingId.Value}");
        _success = res?.Success == true;
        _message = _success ? "Promoción eliminada lógicamente." : (res?.Message ?? "No se pudo eliminar.");
        if (_success)
        {
            await Load();
            NewItem();
        }
    }
}
