@page "/quotes/{PropertyId:int}"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Cotizador</PageTitle>

<div class="pagetitle d-flex justify-content-between align-items-center">
    <div>
        <h1>Cotizador comercial</h1>
        <p class="text-muted mb-0">Cotizá, simulá y guardá propuestas comerciales con desglose tarifario.</p>
    </div>
    <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo($"/quotes/{PropertyId}/saved")'>Ver cotizaciones guardadas</button>
</div>

<div class="card mb-3">
    <div class="card-body pt-3">
        <div class="row g-3">
            <div class="col-md-3"><label class="form-label">Check-in</label><input class="form-control" type="date" @bind="_checkIn" /></div>
            <div class="col-md-3"><label class="form-label">Check-out</label><input class="form-control" type="date" @bind="_checkOut" /></div>
            <div class="col-md-2"><label class="form-label">Adultos</label><input class="form-control" type="number" min="1" @bind="_adults" /></div>
            <div class="col-md-2"><label class="form-label">Niños</label><input class="form-control" type="number" min="0" @bind="_children" /></div>
            <div class="col-md-2"><label class="form-label">Unidad específica</label><select class="form-select" @bind="_unitId"><option value="">Todas</option>@foreach (var u in _units.Where(x => x.IsActive)){<option value="@u.Id">@u.Name</option>}</select></div>
            <div class="col-md-3"><label class="form-label">Huésped</label><input class="form-control" @bind="_guestName" placeholder="Nombre opcional" /></div>
            <div class="col-md-3"><label class="form-label">Email</label><input class="form-control" @bind="_guestEmail" /></div>
            <div class="col-md-2"><label class="form-label">Teléfono</label><input class="form-control" @bind="_guestPhone" /></div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button class="btn btn-primary flex-fill" @onclick="Search">Cotizar</button>
                <button class="btn btn-outline-primary flex-fill" @onclick="SaveCurrentQuote" disabled="@(_quote is null || !_quote.AvailableUnits.Any())">Guardar</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert @(_success ? "alert-success" : "alert-danger")">@_message</div>
}

@if (_quote is not null)
{
    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Resumen</h5>
                    <div class="mb-2">Noches: <strong>@_quote.Nights</strong></div>
                    <div class="mb-2">Tarifa base: <strong>@_quote.BaseAmount.ToString("0.00")</strong></div>
                    <div class="mb-2">Promociones: <strong class="text-success">- @_quote.PromotionsAmount.ToString("0.00")</strong></div>
                    <div class="mb-2">Total final: <strong>@_quote.Total.ToString("0.00")</strong></div>
                    <div>Seña sugerida: <strong>@_quote.SuggestedDepositAmount.ToString("0.00")</strong></div>
                    <hr />
                    <div class="small text-muted">@_quote.Summary</div>
                    @if (_quote.ValidationMessages.Any())
                    {
                        <div class="mt-3 alert alert-warning small mb-0">
                            @foreach (var item in _quote.ValidationMessages)
                            {
                                <div>@item</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Unidades disponibles</h5>
                    @if (!_quote.AvailableUnits.Any())
                    {
                        <EmptyState Title="No hay unidades disponibles" Description="Probá con otras fechas o cambiá la unidad específica." Icon="bi-calendar-x" />
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead><tr><th>Unidad</th><th>Estado</th><th>Base</th><th>Promo</th><th>Total</th><th>Seña</th><th></th></tr></thead>
                                <tbody>
                                @foreach (var u in _quote.AvailableUnits)
                                {
                                    <tr class="@(_selectedUnit?.UnitId == u.UnitId ? "table-primary" : string.Empty)">
                                        <td><strong>@u.UnitName</strong></td>
                                        <td><span class="badge bg-light text-dark border">@u.OperationalStatus</span></td>
                                        <td>@u.BaseAmount.ToString("0.00")</td>
                                        <td class="text-success">- @u.PromotionsAmount.ToString("0.00")</td>
                                        <td><strong>@u.Total.ToString("0.00")</strong></td>
                                        <td>@u.SuggestedDepositAmount.ToString("0.00")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="(() => SelectUnit(u))">Ver desglose</button>
                                            <button class="btn btn-sm btn-primary" @onclick="(()=>GoNewBooking(u))">Crear reserva</button>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_selectedUnit is not null)
    {
        <div class="row g-3">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Desglose tarifario — @_selectedUnit.UnitName</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead><tr><th>Concepto</th><th class="text-end">Importe</th></tr></thead>
                                <tbody>
                                @foreach (var line in _selectedUnit.Lines)
                                {
                                    <tr><td>@line.Label</td><td class="text-end @(line.Amount < 0 ? "text-success" : string.Empty)">@line.Amount.ToString("0.00")</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        @if (_selectedUnit.AppliedPromotions.Any())
                        {
                            <div class="mt-3">
                                <h6>Promociones aplicadas</h6>
                                @foreach (var promo in _selectedUnit.AppliedPromotions)
                                {
                                    <span class="badge bg-success me-1 mb-1">@promo.Name · -@promo.Amount.ToString("0.00")</span>
                                }
                            </div>
                        }
                        @if (_selectedUnit.Rules.Any())
                        {
                            <div class="mt-3 alert alert-warning mb-0 small">
                                @foreach (var rule in _selectedUnit.Rules)
                                {
                                    <div>@rule</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Detalle por noche</h5>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead><tr><th>Fecha</th><th>Base</th><th>Ajustes</th><th class="text-end">Final</th></tr></thead>
                                <tbody>
                                @foreach (var night in _selectedUnit.NightBreakdown)
                                {
                                    <tr>
                                        <td>@night.Date.ToString("dd/MM/yyyy")</td>
                                        <td>@night.BaseRate.ToString("0.00")</td>
                                        <td>
                                            @if (!night.Adjustments.Any())
                                            {
                                                <span class="text-muted">Sin ajustes</span>
                                            }
                                            else
                                            {
                                                @foreach (var adj in night.Adjustments)
                                                {
                                                    <div class="small">@adj.Label: @adj.Amount.ToString("0.00")</div>
                                                }
                                            }
                                        </td>
                                        <td class="text-end"><strong>@night.FinalRate.ToString("0.00")</strong></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int PropertyId { get; set; }
    private DateOnly _checkIn = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    private DateOnly _checkOut = DateOnly.FromDateTime(DateTime.Today.AddDays(3));
    private int _adults = 2;
    private int _children;
    private int? _unitId;
    private string? _guestName;
    private string? _guestEmail;
    private string? _guestPhone;
    private QuoteResultDto? _quote;
    private QuoteAvailableUnitDto? _selectedUnit;
    private List<UnitListItemDto> _units = new();
    private string? _message;
    private bool _success;

    protected override async Task OnParametersSetAsync()
    {
        _units = (await Api.GetAsync<AppResult<List<UnitListItemDto>>>($"api/properties/{PropertyId}/units"))?.Data ?? new();
    }

    private async Task Search()
    {
        _message = null;
        var unitQuery = _unitId.HasValue ? $"&unitId={_unitId.Value}" : string.Empty;
        _quote = (await Api.GetAsync<AppResult<QuoteResultDto>>($"api/properties/{PropertyId}/quotes?checkInDate={_checkIn:yyyy-MM-dd}&checkOutDate={_checkOut:yyyy-MM-dd}&adults={_adults}&children={_children}{unitQuery}"))?.Data;
        _selectedUnit = _quote?.AvailableUnits.OrderBy(x => x.Total).FirstOrDefault();
    }

    private void SelectUnit(QuoteAvailableUnitDto unit) => _selectedUnit = unit;

    private async Task SaveCurrentQuote()
    {
        var res = await Api.PostAsync<SaveQuoteCommand, AppResult<SavedQuoteDto>>($"api/properties/{PropertyId}/quotes/save", new SaveQuoteCommand(PropertyId, _selectedUnit?.UnitId ?? _unitId, _checkIn, _checkOut, _adults, _children, _guestName, _guestEmail, _guestPhone));
        _success = res?.Success == true;
        _message = _success ? $"Cotización guardada correctamente. Token: {res?.Data?.PublicToken}" : (res?.Message ?? "No se pudo guardar la cotización.");
    }

    private void GoNewBooking(QuoteAvailableUnitDto u)
        => Nav.NavigateTo($"/bookings/new/{PropertyId}?unitId={u.UnitId}&checkIn={_checkIn:yyyy-MM-dd}&checkOut={_checkOut:yyyy-MM-dd}&adults={_adults}&children={_children}&total={u.Total}&createdFromQuote=true");
}
