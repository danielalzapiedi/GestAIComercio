@page "/housekeeping/{PropertyId:int}"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Housekeeping</PageTitle>
<h1 class="h3 mb-3">Housekeeping / Limpieza</h1>

@if (_tasks is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <div class="card"><div class="card-body"><h5 class="card-title">Tareas pendientes</h5>
            @if (_tasks.Count == 0){<p class="text-muted">No hay tareas pendientes.</p>}
            else {
                <div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Unidad</th><th>Título</th><th>Fecha</th><th>Prioridad</th><th>Reserva</th><th></th></tr></thead><tbody>
                @foreach (var task in _tasks)
                {
                    <tr><td>@task.UnitName</td><td>@task.Title<div class="small text-muted">@task.Notes</div></td><td>@task.ScheduledDate</td><td>@task.Priority</td><td>@task.BookingCode</td><td class="text-end"><button class="btn btn-sm btn-outline-primary me-2" @onclick="(()=>OpenBooking(task.BookingId))">Abrir</button><button class="btn btn-sm btn-success" @onclick="(()=>Complete(task.Id))">Marcar limpieza completada</button></td></tr>
                }
                </tbody></table></div>
            }
            </div></div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card"><div class="card-body"><h5 class="card-title">Estado de unidades</h5>
            @if (_units.Count == 0){<p class="text-muted">Sin unidades.</p>} else {
                <ul class="list-group list-group-flush">@foreach (var u in _units.Where(x => x.OperationalStatus == UnitOperationalStatus.PendingCleaning || x.OperationalStatus == UnitOperationalStatus.Cleaning || x.OperationalStatus == UnitOperationalStatus.Clean)){<li class="list-group-item d-flex justify-content-between"><span>@u.Name</span><span class="badge bg-secondary">@u.OperationalStatus</span></li>}</ul>
            }
            </div></div>
        </div>
    </div>
}

@code {
    [Parameter] public int PropertyId { get; set; }
    private List<OperationalTaskDto>? _tasks; private List<UnitListItemDto> _units = new();
    protected override async Task OnParametersSetAsync() => await Load();
    private async Task Load(){ _tasks = (await Api.GetAsync<AppResult<List<OperationalTaskDto>>>($"api/properties/{PropertyId}/operations/tasks?status={OperationalTaskStatus.Pending}&type={OperationalTaskType.Cleaning}"))?.Data ?? new(); _units = (await Api.GetAsync<AppResult<List<UnitListItemDto>>>($"api/properties/{PropertyId}/units"))?.Data ?? new(); }
    private async Task Complete(int taskId){ await Api.PostJsonAsync<AppResult, object>($"api/properties/{PropertyId}/operations/tasks/{taskId}/complete", new { }); await Load(); }
    private void OpenBooking(int? bookingId){ if (bookingId.HasValue) Nav.NavigateTo($"/bookings/{PropertyId}/{bookingId.Value}"); }
}
