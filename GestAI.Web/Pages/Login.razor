@page "/login"
@inject ApiClient Api
@inject JwtAuthStateProvider Auth
@inject NavigationManager Nav
@inject ITokenStore TokenStore
@layout BareLayout
@attribute [AllowAnonymous]

<main class="ui-auth-shell">
    <section class="ui-auth-hero">
        <div class="ui-auth-kicker">
            <i class="bi bi-stars"></i>
            <span>Plataforma moderna de gestión comercial</span>
        </div>
        <div>
            <div class="ui-auth-title">Controlá tu operación desde un solo lugar.</div>
            <p class="ui-auth-copy">
                Gestioná sucursales, depósitos, categorías, productos, clientes, proveedores y usuarios
                con una experiencia más clara, rápida y orientada al trabajo diario.
            </p>
        </div>
        <div class="ui-auth-feature-grid">
            <div class="ui-auth-feature">
                <strong>Panel comercial unificado</strong>
                <div class="small mt-1 text-white-50">Todo el flujo operativo accesible en una sola navegación.</div>
            </div>
            <div class="ui-auth-feature">
                <strong>Permisos por módulo</strong>
                <div class="small mt-1 text-white-50">Más control sobre lo que cada usuario puede hacer.</div>
            </div>
            <div class="ui-auth-feature">
                <strong>Diseño claro y actual</strong>
                <div class="small mt-1 text-white-50">Menos ruido visual, mejor lectura y decisiones más rápidas.</div>
            </div>
            <div class="ui-auth-feature">
                <strong>Preparado para crecer</strong>
                <div class="small mt-1 text-white-50">Base lista para operación multi-tenant y administración central.</div>
            </div>
        </div>
    </section>

    <section class="ui-auth-panel">
        <div class="ui-auth-card">
            <a href="/" class="ui-auth-logo">
                <span class="ui-brand-mark"><i class="bi bi-shop-window"></i></span>
                <span>
                    <strong class="d-block">GestAI Comercio</strong>
                    <span class="text-muted small">Ingresá para continuar</span>
                </span>
            </a>

            <div class="mb-4">
                <h1 class="page-hero-title mb-1">Bienvenido</h1>
                <p class="page-hero-subtitle mb-0">Usá tu email y contraseña para entrar al sistema.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <Alert Message="@_error" CssClass="alert-danger" />
            }

            <EditForm Model="_vm" OnValidSubmit="DoLogin" class="row g-3 needs-validation">
                <DataAnnotationsValidator />

                <div class="col-12">
                    <label class="form-label">Email</label>
                    <div class="input-group has-validation">
                        <span class="input-group-text">@@</span>
                        <InputText class="form-control" @bind-Value="_vm.Email" placeholder="nombre@empresa.com" />
                    </div>
                    <ValidationMessage For="@(() => _vm.Email)" />
                </div>

                <div class="col-12">
                    <label class="form-label">Contraseña</label>
                    <InputText class="form-control" type="password" @bind-Value="_vm.Password" placeholder="Ingresá tu contraseña" />
                    <ValidationMessage For="@(() => _vm.Password)" />
                </div>

                <div class="col-12">
                    <button class="btn btn-primary w-100" type="submit" disabled="@_busy">
                        <i class="bi bi-arrow-right-circle me-2"></i>
                        @(_busy ? "Ingresando..." : "Ingresar al sistema")
                    </button>
                </div>
            </EditForm>

            <div class="ui-auth-footer">
                GestAI Comercio · experiencia renovada para operación diaria.
            </div>
        </div>
    </section>
</main>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? returnUrl { get; set; }

    private LoginVm _vm = new();
    private string? _error;
    private bool _busy;

    private async Task DoLogin()
    {
        _error = null;
        _busy = true;

        try
        {
            var req = new LoginRequest(_vm.Email, _vm.Password);

            // ✅ mejor: usar PostAsync<TReq, TRes>
            var res = await Api.PostAsync<LoginRequest, LoginResponse>("api/auth/login", req);

            if (res is null || string.IsNullOrWhiteSpace(res.Token))
            {
                _error = "Respuesta inválida del servidor.";
                return;
            }

            await TokenStore.SetAsync(res.Token);
            await Auth.SetTokenAsync(res.Token);

            var target = NormalizeReturnUrl(returnUrl);
            Nav.NavigateTo(target, forceLoad: false);
        }
        catch (Exception ex)
        {
            // si querés ver el detalle en dev:
            // _error = ex.Message;
            _error = "Credenciales inválidas";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string NormalizeReturnUrl(string? url)
    {
        // seguridad básica: solo rutas internas
        if (string.IsNullOrWhiteSpace(url)) return "/dashboard";
        if (!url.StartsWith("/")) return "/dashboard";
        if (url.StartsWith("//")) return "/dashboard";
        return url;
    }

    private sealed class LoginVm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email requerido.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email inválido.")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Contraseña requerida.")]
        public string Password { get; set; } = "";
    }

    public record LoginRequest(string Email, string Password);
    public record LoginResponse(string Token, DateTime Expires);
}
