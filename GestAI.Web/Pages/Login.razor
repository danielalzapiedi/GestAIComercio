@page "/login"
@inject ApiClient Api
@inject JwtAuthStateProvider Auth
@inject NavigationManager Nav
@inject ITokenStore TokenStore
@layout BareLayout
@attribute [AllowAnonymous]

<main>
    <div class="container">
        <section class="section register min-vh-100 d-flex flex-column align-items-center justify-content-center py-4">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-4 col-md-6 d-flex flex-column align-items-center justify-content-center">

                        <div class="d-flex justify-content-center py-4">
                            <a href="/" class="logo d-flex align-items-center w-auto">
                                <img src="assets/img/logo.png" alt="">
                                <span class="d-none d-lg-block">GestAI Booking</span>
                            </a>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body">

                                <div class="pt-4 pb-2">
                                    <h5 class="card-title text-center pb-0 fs-4">Ingresar a su cuenta</h5>
                                    <p class="text-center small">Ingresá tu email y contraseña para acceder al sistema</p>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_error))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        @_error
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                }

                                <EditForm Model="_vm" OnValidSubmit="DoLogin" class="row g-3 needs-validation">
                                    <DataAnnotationsValidator />

                                    <div class="col-12">
                                        <label class="form-label">Email</label>
                                        <div class="input-group has-validation">
                                            <span class="input-group-text">@@</span>
                                            <InputText class="form-control" @bind-Value="_vm.Email" />
                                        </div>
                                        <ValidationMessage For="@(() => _vm.Email)" />
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Contraseña</label>
                                        <InputText class="form-control" type="password" @bind-Value="_vm.Password" />
                                        <ValidationMessage For="@(() => _vm.Password)" />
                                    </div>

                                    <div class="col-12">
                                        <button class="btn btn-primary w-100" type="submit" disabled="@_busy">
                                            @(_busy ? "Ingresando..." : "Ingresar")
                                        </button>
                                    </div>
                                </EditForm>

                            </div>
                        </div>

                        <div class="credits">
                            GestAI Booking · gestión operativa para hospedajes
                        </div>

                    </div>
                </div>
            </div>
        </section>
    </div>
</main>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? returnUrl { get; set; }

    private LoginVm _vm = new();
    private string? _error;
    private bool _busy;

    private async Task DoLogin()
    {
        _error = null;
        _busy = true;

        try
        {
            var req = new LoginRequest(_vm.Email, _vm.Password);

            // ✅ mejor: usar PostAsync<TReq, TRes>
            var res = await Api.PostAsync<LoginRequest, LoginResponse>("api/auth/login", req);

            if (res is null || string.IsNullOrWhiteSpace(res.Token))
            {
                _error = "Respuesta inválida del servidor.";
                return;
            }

            await TokenStore.SetAsync(res.Token);
            await Auth.SetTokenAsync(res.Token);

            var target = NormalizeReturnUrl(returnUrl);
            Nav.NavigateTo(target, forceLoad: false);
        }
        catch (Exception ex)
        {
            // si querés ver el detalle en dev:
            // _error = ex.Message;
            _error = "Credenciales inválidas";
        }
        finally
        {
            _busy = false;
        }
    }

    private static string NormalizeReturnUrl(string? url)
    {
        // seguridad básica: solo rutas internas
        if (string.IsNullOrWhiteSpace(url)) return "/setup";
        if (!url.StartsWith("/")) return "/setup";
        if (url.StartsWith("//")) return "/setup";
        return url;
    }

    private sealed class LoginVm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email requerido.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Email inválido.")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Contraseña requerida.")]
        public string Password { get; set; } = "";
    }

    public record LoginRequest(string Email, string Password);
    public record LoginResponse(string Token, DateTime Expires);
}
