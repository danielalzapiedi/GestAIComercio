@page "/audit-log"
@inject ApiClient Api
@using GestAI.Web.Dtos

<PageTitle>Auditoría</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Auditoría</div>
        <div class="page-hero-subtitle">Log de negocio legible: usuario, fecha, entidad, acción y resumen entendible para operación administrativa.</div>
    </div>
    <div class="page-hero-meta">
        <span class="page-hero-chip"><i class="bi bi-journal-text"></i> @TotalItems registros</span>
        <a class="btn btn-outline-secondary" href="/document-history">Ver historial documental</a>
    </div>
</section>

<div class="card ui-filter-card mb-3"><div class="card-body">
    <div class="row g-2 align-items-end">
        <div class="col-lg-4"><label class="form-label">Entidad</label><input class="form-control" @bind="_entityName" placeholder="Sale, PurchaseDocument, CommercialInvoice..." /></div>
        <div class="col-lg-4"><label class="form-label">Usuario</label><input class="form-control" @bind="_userName" placeholder="Nombre o email" /></div>
        <div class="col-lg-2"><label class="form-label">Desde</label><input class="form-control" type="date" @bind-value="_from" /></div>
        <div class="col-lg-2"><button class="btn btn-outline-primary w-100" type="button" @onclick="Load">Filtrar</button></div>
    </div>
</div></div>

@if (_items is null)
{
    <div class="card"><div class="card-body">Cargando auditoría...</div></div>
}
else if (_items.Count == 0)
{
    <EmptyState Title="Todavía no hay eventos de auditoría"
                Description="Cuando el tenant registre acciones relevantes, vas a poder revisarlas desde esta pantalla."
                Icon="bi-journal-text" />
}
else
{
    <div class="row g-3 ui-summary-grid mb-1">
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Eventos</div><div class="ui-stat-value">@TotalItems</div><div class="ui-stat-foot">Últimos movimientos cargados para esta vista.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Entidades</div><div class="ui-stat-value">@DistinctEntities</div><div class="ui-stat-foot">Tipos de entidades involucradas en los eventos.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Usuarios</div><div class="ui-stat-value">@DistinctUsers</div><div class="ui-stat-foot">Usuarios distintos que generaron actividad.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Último evento</div><div class="ui-stat-value">@LatestEventLabel</div><div class="ui-stat-foot">Fecha del evento más reciente visible.</div></div></div></div>
    </div>

    <div class="card ui-data-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Trazabilidad del tenant</div>
                    <h5 class="ui-card-title">Registro reciente de auditoría</h5>
                    <div class="ui-card-subtitle">Vista resumida de acciones sobre entidades y usuarios del sistema.</div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Entidad</th>
                            <th>Acción</th>
                            <th>Resumen</th>
                            <th>Usuario</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td>
                                <div class="ui-table-stack">
                                    <span class="fw-semibold">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                    <span class="ui-table-meta">@item.CreatedAtUtc.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            </td>
                            <td><span class="fw-semibold">@item.EntityName</span></td>
                            <td><StatusBadge Text="@item.Action" /></td>
                            <td>@item.Summary</td>
                            <td>@(string.IsNullOrWhiteSpace(item.UserName) ? "Sistema" : item.UserName)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<AccountAuditItemDto>? _items;
    private string _entityName = string.Empty;
    private string _userName = string.Empty;
    private DateTime? _from;

    private int TotalItems => _items?.Count ?? 0;
    private int DistinctEntities => _items?.Select(x => x.EntityName).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count() ?? 0;
    private int DistinctUsers => _items?.Select(x => x.UserName).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count() ?? 0;
    private string LatestEventLabel => _items?.FirstOrDefault() is { } item ? item.CreatedAtUtc.ToLocalTime().ToString("dd/MM") : "-";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        var entity = string.IsNullOrWhiteSpace(_entityName) ? string.Empty : $"&entityName={Uri.EscapeDataString(_entityName)}";
        var user = string.IsNullOrWhiteSpace(_userName) ? string.Empty : $"&userName={Uri.EscapeDataString(_userName)}";
        var from = _from.HasValue ? $"&from={DateOnly.FromDateTime(_from.Value):yyyy-MM-dd}" : string.Empty;
        _items = (await Api.GetAsync<AppResult<List<AccountAuditItemDto>>>($"api/saas/account/audit?take=100{entity}{user}{from}"))?.Data ?? new();
    }
}
