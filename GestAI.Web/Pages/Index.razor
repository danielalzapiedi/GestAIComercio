@page "/"
@inject ApiClient Api
@inject NavigationManager Navigation
@using GestAI.Web.Dtos

@if (!_loaded)
{
    <p>Cargando...</p>
}

@code {
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Api.GetAsync<AppResult<SetupStatusDto>>("api/setup/status");

            if (res?.Success == true && res.Data?.DefaultPropertyId != null)
            {
                Navigation.NavigateTo($"/dashboard/{res.Data.DefaultPropertyId}");
            }
            else
            {
                Navigation.NavigateTo("/setup");
            }
        }
        finally
        {
            _loaded = true;
        }
    }
}
