@page "/cash"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject ProductTelemetryService Telemetry

<PageTitle>Caja</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Caja operativa</div>
        <div class="page-hero-subtitle">Control de apertura/cierre, saldo actual y trazabilidad de ingresos y egresos vinculados a la operatoria diaria.</div>
    </div>
    <div class="page-hero-meta">
        <span class="page-hero-chip"><i class="bi bi-safe2"></i> @(_dashboard?.Register.Name ?? "Caja principal")</span>
        <span class="page-hero-chip"><i class="bi bi-wallet2"></i> @((_dashboard?.CurrentBalance ?? 0m).ToString("C"))</span>
    </div>
</section>

<FormFeedback Error="@_error" Success="@_success" ValidationErrors="@ValidationSummary" />
<OperationalStateHint IsLoading="@_loading" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="false" />

@if (_dashboard is null)
{
    <div class="card ui-data-card"><div class="card-body">Cargando caja...</div></div>
}
else
{
    <div class="row g-3 ui-summary-grid mb-3">
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Saldo actual</div><div class="ui-stat-value">@_dashboard.CurrentBalance.ToString("C")</div><div class="ui-stat-foot">Saldo consolidado de la caja principal.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Ingresos</div><div class="ui-stat-value">@_dashboard.TotalIn.ToString("C")</div><div class="ui-stat-foot">Movimientos de entrada registrados.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Egresos</div><div class="ui-stat-value">@_dashboard.TotalOut.ToString("C")</div><div class="ui-stat-foot">Salidas de caja registradas.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Estado</div><div class="ui-stat-value">@(_dashboard.OpenSession is null ? "Cerrada" : "Abierta")</div><div class="ui-stat-foot">@(_dashboard.OpenSession is null ? "Abrí una caja para operar." : $"Desde {_dashboard.OpenSession.OpenedAtUtc.ToLocalTime():dd/MM HH:mm}")</div></div></div></div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-xl-4">
            <div class="card ui-data-card"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Apertura / cierre</div><h5 class="ui-card-title">Sesión de caja</h5><div class="ui-card-subtitle">Una sola sesión abierta por caja, preparada para crecer a múltiples cajas.</div></div></div>
                @if (_dashboard.OpenSession is null)
                {
                    <div class="mb-3 small text-muted">No hay una sesión abierta. Registrá el saldo inicial para comenzar a operar.</div>
                    <div class="mb-3">
                        <label class="form-label">Saldo inicial</label>
                        <input type="number" step="0.01" class="form-control @(HasValidationError(nameof(_open.OpeningBalance)) ? "is-invalid" : null)" @bind="_open.OpeningBalance" />
                        @if (TryGetValidationMessage(nameof(_open.OpeningBalance), out var openingError))
                        {
                            <div class="invalid-feedback d-block">@openingError</div>
                        }
                    </div>
                    <div class="mb-3"><label class="form-label">Observación</label><textarea class="form-control" rows="3" @bind="_open.Note"></textarea></div>
                    <button class="btn btn-primary" @onclick="OpenCash" aria-label="Abrir caja con saldo inicial">Abrir caja</button>
                }
                else
                {
                    <div class="border rounded-3 p-3 mb-3 bg-light-subtle">
                        <div class="small text-muted">Saldo esperado actual</div>
                        <div class="h4 mb-0">@_dashboard.OpenSession.CurrentBalance.ToString("C")</div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6"><div class="border rounded-3 p-2"><div class="small text-muted">Apertura</div><div class="fw-semibold">@_dashboard.OpenSession.OpeningBalance.ToString("C")</div></div></div>
                        <div class="col-6"><div class="border rounded-3 p-2"><div class="small text-muted">Abierta por</div><div class="fw-semibold">@_dashboard.OpenSession.OpenedByUserId</div></div></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Saldo contado al cierre</label>
                        <input type="number" step="0.01" class="form-control @(HasValidationError(nameof(_close.ClosingBalanceDeclared)) ? "is-invalid" : null)" @bind="_close.ClosingBalanceDeclared" />
                        @if (TryGetValidationMessage(nameof(_close.ClosingBalanceDeclared), out var closingError))
                        {
                            <div class="invalid-feedback d-block">@closingError</div>
                        }
                    </div>
                    <div class="mb-3"><label class="form-label">Observación de cierre</label><textarea class="form-control" rows="3" @bind="_close.Note"></textarea></div>
                    <button class="btn btn-outline-danger" @onclick="CloseCash" aria-label="Cerrar caja con saldo declarado">Cerrar caja</button>
                }
            </div></div>
        </div>
        <div class="col-xl-4">
            <div class="card ui-data-card"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Ingreso / egreso</div><h5 class="ui-card-title">Movimiento manual</h5><div class="ui-card-subtitle">Para gastos menores, retiros, adelantos o ingresos sin cuenta corriente.</div></div></div>
                <div class="mb-3"><label class="form-label">Tipo</label><select class="form-select" @bind="_manual.Direction"><option value="@CashMovementDirection.In">Ingreso</option><option value="@CashMovementDirection.Out">Egreso</option></select></div>
                <div class="mb-3">
                    <label class="form-label">Importe</label>
                    <input type="number" step="0.01" class="form-control @(HasValidationError(nameof(_manual.Amount)) ? "is-invalid" : null)" @bind="_manual.Amount" />
                    @if (TryGetValidationMessage(nameof(_manual.Amount), out var movementError))
                    {
                        <div class="invalid-feedback d-block">@movementError</div>
                    }
                </div>
                <div class="mb-3"><label class="form-label">Concepto</label><input class="form-control" @bind="_manual.Concept" /></div>
                <div class="mb-3"><label class="form-label">Fecha</label><input type="datetime-local" class="form-control" @bind="_manualDate" /></div>
                <div class="mb-3"><label class="form-label">Observaciones</label><textarea class="form-control" rows="3" @bind="_manual.Observations"></textarea></div>
                <button class="btn btn-primary" @onclick="SaveManualMovement" disabled="@(_dashboard.OpenSession is null)" aria-label="Registrar movimiento manual en caja">Registrar movimiento</button>
                @if (_dashboard.OpenSession is null)
                {
                    <div class="small text-muted mt-2">Necesitás una caja abierta para registrar movimientos.</div>
                }
            </div></div>
        </div>
        <div class="col-xl-4">
            <div class="card ui-data-card"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Acciones principales</div><h5 class="ui-card-title">Flujos vinculados</h5><div class="ui-card-subtitle">Los cobros y pagos impactan caja y cuentas corrientes desde sus pantallas específicas.</div></div></div>
                <div class="d-grid gap-2">
                    <a class="btn btn-outline-primary" href="/customer-current-accounts"><i class="bi bi-person-lines-fill me-2"></i>Ir a cuentas corrientes de clientes</a>
                    <a class="btn btn-outline-primary" href="/supplier-current-accounts"><i class="bi bi-journal-richtext me-2"></i>Ir a cuentas corrientes de proveedores</a>
                </div>
                <hr />
                <div class="small text-muted">Decisión de diseño: la release opera sobre una caja principal preparada para crecer a múltiples cajas mediante <strong>CashRegister</strong> + <strong>CashSession</strong>.</div>
            </div></div>
        </div>
    </div>

    <div class="card ui-data-card"><div class="card-body">
        <div class="ui-card-header"><div><div class="ui-card-eyebrow">Trazabilidad</div><h5 class="ui-card-title">Últimos movimientos</h5><div class="ui-card-subtitle">Cada cobro, pago o ajuste queda visible con referencia, tercero y concepto.</div></div></div>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead><tr><th>Fecha</th><th>Referencia</th><th>Origen</th><th>Tercero</th><th>Concepto</th><th>Ingreso</th><th>Egreso</th></tr></thead>
                <tbody>
                @foreach (var item in _dashboard.RecentMovements)
                {
                    <tr>
                        <td>@item.OccurredAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.ReferenceNumber</td>
                        <td>@OriginLabel(item.OriginType)</td>
                        <td>@(item.CustomerName ?? item.SupplierName ?? "-")</td>
                        <td><div class="ui-table-stack"><span class="fw-semibold">@item.Concept</span><span class="ui-table-meta">@item.Observations</span></div></td>
                        <td>@(item.Direction == CashMovementDirection.In ? item.Amount.ToString("C") : "-")</td>
                        <td>@(item.Direction == CashMovementDirection.Out ? item.Amount.ToString("C") : "-")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div></div>
}

@code {
    private CashDashboardDto? _dashboard;
    private OpenCashSessionCommand _open = new();
    private CloseCashSessionCommand _close = new();
    private CreateCashManualMovementCommand _manual = new();
    private DateTime _manualDate = DateTime.UtcNow;
    private string? _error;
    private string? _success;
    private bool _loading = true;
    private bool _saving;
    private readonly Dictionary<string, string> _validation = new();
    private IReadOnlyList<string> ValidationSummary => _validation.Values.ToList();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _error = null;
        try
        {
            _dashboard = (await Api.GetAsync<AppResult<CashDashboardDto>>("api/commerce/cash"))?.Data;
            _manualDate = DateTime.UtcNow;
            if (_dashboard?.OpenSession is not null)
                _close.ClosingBalanceDeclared = _dashboard.OpenSession.CurrentBalance;
            Telemetry.Track("cash", "load", "success", _dashboard?.OpenSession is null ? "closed" : "open");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("cash", "load", "error", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCash()
    {
        _validation.Clear();
        if (_open.OpeningBalance < 0m)
        {
            _validation[nameof(_open.OpeningBalance)] = "El saldo inicial no puede ser negativo.";
            Telemetry.Track("cash", "validate", "error", _validation[nameof(_open.OpeningBalance)]);
            return;
        }

        await Execute("open", async () => await Api.PostAsync<OpenCashSessionCommand, AppResult<int>>("api/commerce/cash/open", _open));
        _open = new();
    }

    private async Task CloseCash()
    {
        _validation.Clear();
        if (_dashboard?.OpenSession is null)
        {
            _validation[nameof(_dashboard.OpenSession)] = "No hay una sesión abierta para cerrar.";
            Telemetry.Track("cash", "validate", "error", _validation[nameof(_dashboard.OpenSession)]);
            return;
        }

        if (_close.ClosingBalanceDeclared < 0m)
        {
            _validation[nameof(_close.ClosingBalanceDeclared)] = "El saldo declarado de cierre no puede ser negativo.";
            Telemetry.Track("cash", "validate", "error", _validation[nameof(_close.ClosingBalanceDeclared)]);
            return;
        }

        await Execute("close", async () => await Api.PostAsync<CloseCashSessionCommand, AppResult>("api/commerce/cash/close", _close));
        _close = new();
    }

    private async Task SaveManualMovement()
    {
        _validation.Clear();
        if (_manual.Amount <= 0m)
        {
            _validation[nameof(_manual.Amount)] = "Ingresá un importe mayor a cero para registrar el movimiento.";
            Telemetry.Track("cash", "validate", "error", _validation[nameof(_manual.Amount)]);
            return;
        }

        _manual.OccurredAtUtc = DateTime.SpecifyKind(_manualDate, DateTimeKind.Local).ToUniversalTime();
        await Execute("manual-movement", async () => await Api.PostAsync<CreateCashManualMovementCommand, AppResult<int>>("api/commerce/cash/movements", _manual));
        _manual = new();
        _manualDate = DateTime.UtcNow;
    }

    private async Task Execute(string actionName, Func<Task<object?>> action)
    {
        _saving = true;
        _error = null;
        _success = null;
        try
        {
            var response = await action();
            if (response is AppResult result && !result.Success)
            {
                _error = result.Message;
                Telemetry.Track("cash", actionName, "error", _error);
                return;
            }

            if (response is AppResult<int> resultInt && !resultInt.Success)
            {
                _error = resultInt.Message;
                Telemetry.Track("cash", actionName, "error", _error);
                return;
            }

            _success = "Operación registrada correctamente.";
            Telemetry.Track("cash", actionName, "success");
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("cash", actionName, "error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private static string OriginLabel(CashMovementOriginType origin) => origin switch
    {
        CashMovementOriginType.Opening => "Apertura",
        CashMovementOriginType.Manual => "Manual",
        CashMovementOriginType.CustomerCollection => "Cobro",
        CashMovementOriginType.SupplierPayment => "Pago",
        CashMovementOriginType.ClosingAdjustment => "Ajuste de cierre",
        _ => origin.ToString()
    };

    private bool HasValidationError(string key) => _validation.ContainsKey(key);
    private bool TryGetValidationMessage(string key, out string message) => _validation.TryGetValue(key, out message!);
}
