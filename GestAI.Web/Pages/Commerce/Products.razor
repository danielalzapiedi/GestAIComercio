@page "/products"
@using GestAI.Web.Dtos
@inject ApiClient Api

<PageTitle>Productos</PageTitle>

<h1>Productos</h1>
<div class="card mb-3"><div class="card-body">
    <div class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Nombre, código, marca" /></div>
        <div class="col-md-3"><label class="form-label">Categoría</label><select class="form-select" @bind="_selectedCategoryId"><option value="0">Todas</option>@foreach (var category in _seed.Categories){<option value="@category.Id">@category.Name</option>}</select></div>
        <div class="col-md-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activos</option><option value="false">Inactivos</option></select></div>
        <div class="col-md-2"><button class="btn btn-outline-primary" @onclick="Load">Buscar</button></div>
        <div class="col-md-2 text-md-end"><button class="btn btn-primary" @onclick="NewItem">Nuevo producto</button></div>
    </div>
</div></div>

@if (!_loaded)
{
    <p>Cargando...</p>
}
else if (_result?.Items.Count == 0)
{
    <div class="alert alert-info">No hay productos.</div>
}
else
{
    <table class="table table-striped">
        <thead><tr><th>Nombre</th><th>Código</th><th>Categoría</th><th>Marca</th><th>Precio</th><th>Variantes</th><th>Estado</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in _result!.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.InternalCode</td>
                <td>@item.CategoryName</td>
                <td>@item.Brand</td>
                <td>@item.SalePrice.ToString("C")</td>
                <td>@item.VariantsCount</td>
                <td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "Activo" : "Inactivo")</span></td>
                <td><button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(item)">Editar</button><button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(item)">@(item.IsActive ? "Desactivar" : "Activar")</button></td>
            </tr>
        }
        </tbody>
    </table>
}

@if (_showForm)
{
    <div class="card mt-4"><div class="card-body">
        <h5>@(_form.Id == 0 ? "Nuevo producto" : "Editar producto")</h5>
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" /></div>
            <div class="col-md-2"><label class="form-label">Código interno</label><input class="form-control" @bind="_form.InternalCode" /></div>
            <div class="col-md-2"><label class="form-label">Código barras</label><input class="form-control" @bind="_form.Barcode" /></div>
            <div class="col-md-4"><label class="form-label">Descripción</label><input class="form-control" @bind="_form.Description" /></div>
            <div class="col-md-3"><label class="form-label">Categoría</label><select class="form-select" @bind="_form.CategoryId">@foreach (var category in _seed.Categories){<option value="@category.Id">@category.Name</option>}</select></div>
            <div class="col-md-3"><label class="form-label">Marca</label><input class="form-control" @bind="_form.Brand" list="brands-list" /></div>
            <div class="col-md-2"><label class="form-label">Unidad</label><select class="form-select" @bind="_form.UnitOfMeasure">@foreach (var unit in _seed.Units){<option value="@unit">@UnitLabel(unit)</option>}</select></div>
            <div class="col-md-2"><label class="form-label">Costo</label><input class="form-control" type="number" step="0.01" @bind="_form.Cost" /></div>
            <div class="col-md-2"><label class="form-label">Precio</label><input class="form-control" type="number" step="0.01" @bind="_form.SalePrice" /></div>
            <div class="col-md-2"><label class="form-label">Stock mínimo</label><input class="form-control" type="number" step="0.01" @bind="_form.MinimumStock" /></div>
            <div class="col-md-2"><label class="form-label">Activo</label><input type="checkbox" class="form-check-input ms-2" @bind="_form.IsActive" /></div>
        </div>
        <datalist id="brands-list">@foreach (var brand in _seed.Brands){<option value="@brand"></option>}</datalist>
        <div class="mt-3"><button class="btn btn-primary me-2" @onclick="Save">Guardar</button><button class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button></div>

        @if (_form.Id > 0)
        {
            <hr />
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Variantes</h6>
                <button class="btn btn-sm btn-outline-primary" @onclick="NewVariant">Nueva variante</button>
            </div>
            @if (_variants.Count == 0)
            {
                <p class="text-muted">Este producto no tiene variantes aún.</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead><tr><th>Nombre</th><th>Código</th><th>Atributos</th><th>Precio</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var variant in _variants)
                    {
                        <tr>
                            <td>@variant.Name</td>
                            <td>@variant.InternalCode</td>
                            <td>@variant.AttributesSummary</td>
                            <td>@variant.SalePrice.ToString("C")</td>
                            <td>@(variant.IsActive ? "Activo" : "Inactivo")</td>
                            <td><button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditVariant(variant)">Editar</button><button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleVariant(variant)">@(variant.IsActive ? "Desactivar" : "Activar")</button></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            @if (_showVariantForm)
            {
                <div class="border rounded p-3 bg-light">
                    <h6>@(_variantForm.Id == 0 ? "Nueva variante" : "Editar variante")</h6>
                    <div class="row g-3">
                        <div class="col-md-3"><label class="form-label">Nombre</label><input class="form-control" @bind="_variantForm.Name" /></div>
                        <div class="col-md-2"><label class="form-label">Código interno</label><input class="form-control" @bind="_variantForm.InternalCode" /></div>
                        <div class="col-md-2"><label class="form-label">Código barras</label><input class="form-control" @bind="_variantForm.Barcode" /></div>
                        <div class="col-md-3"><label class="form-label">Atributos</label><input class="form-control" @bind="_variantForm.AttributesSummary" placeholder="Ej: Color rojo / 2m" /></div>
                        <div class="col-md-1"><label class="form-label">Costo</label><input class="form-control" type="number" step="0.01" @bind="_variantForm.Cost" /></div>
                        <div class="col-md-1"><label class="form-label">Precio</label><input class="form-control" type="number" step="0.01" @bind="_variantForm.SalePrice" /></div>
                        <div class="col-md-2"><label class="form-label">Activa</label><input type="checkbox" class="form-check-input ms-2" @bind="_variantForm.IsActive" /></div>
                    </div>
                    <div class="mt-3"><button class="btn btn-primary btn-sm me-2" @onclick="SaveVariant">Guardar variante</button><button class="btn btn-outline-secondary btn-sm" @onclick="CancelVariant">Cancelar</button></div>
                </div>
            }
        }
    </div></div>
}

@code {
    private PagedResult<ProductListItemDto>? _result;
    private ProductSeedDataDto _seed = new(new List<LookupDto>(), new List<string>(), Array.Empty<UnitOfMeasure>());
    private List<ProductVariantListItemDto> _variants = new();
    private string _search = string.Empty;
    private int _selectedCategoryId;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _showForm;
    private bool _showVariantForm;
    private ProductUpsertCommand _form = new();
    private ProductVariantUpsertCommand _variantForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSeed();
        await Load();
    }

    private async Task LoadSeed()
    {
        _seed = (await Api.GetAsync<AppResult<ProductSeedDataDto>>("api/commerce/products/seed"))?.Data ?? new ProductSeedDataDto(new List<LookupDto>(), new List<string>(), Enum.GetValues<UnitOfMeasure>());
    }

    private async Task Load()
    {
        _loaded = false;
        var category = _selectedCategoryId > 0 ? $"&categoryId={_selectedCategoryId}" : string.Empty;
        var active = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
        _result = (await Api.GetAsync<AppResult<PagedResult<ProductListItemDto>>>($"api/commerce/products?search={Uri.EscapeDataString(_search ?? string.Empty)}{category}{active}"))?.Data;
        _loaded = true;
    }

    private void NewItem()
    {
        _form = new ProductUpsertCommand { IsActive = true, UnitOfMeasure = UnitOfMeasure.Unit, CategoryId = _seed.Categories.FirstOrDefault()?.Id ?? 0 };
        _variants = new();
        _showVariantForm = false;
        _showForm = true;
    }

    private async Task Edit(ProductListItemDto item)
    {
        var detail = (await Api.GetAsync<AppResult<ProductDetailDto>>($"api/commerce/products/{item.Id}"))?.Data;
        if (detail is null) return;
        _form = new ProductUpsertCommand
        {
            Id = detail.Id,
            Name = detail.Name,
            InternalCode = detail.InternalCode,
            Barcode = detail.Barcode,
            Description = detail.Description,
            CategoryId = detail.CategoryId,
            Brand = detail.Brand,
            UnitOfMeasure = detail.UnitOfMeasure,
            Cost = detail.Cost,
            SalePrice = detail.SalePrice,
            MinimumStock = detail.MinimumStock,
            IsActive = detail.IsActive
        };
        _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{item.Id}/variants"))?.Data ?? new();
        _showVariantForm = false;
        _showForm = true;
    }

    private async Task Save()
    {
        if (_form.Id == 0)
        {
            var response = await Api.PostAsync<object, AppResult<int>>("api/commerce/products", new { _form.Name, _form.InternalCode, _form.Barcode, _form.Description, _form.CategoryId, _form.Brand, _form.UnitOfMeasure, _form.Cost, _form.SalePrice, _form.MinimumStock, _form.IsActive });
            if (response?.Data is int productId)
            {
                _form.Id = productId;
                _variants = new();
            }
        }
        else
        {
            await Api.PutAsync($"api/commerce/products/{_form.Id}", new { _form.Id, _form.Name, _form.InternalCode, _form.Barcode, _form.Description, _form.CategoryId, _form.Brand, _form.UnitOfMeasure, _form.Cost, _form.SalePrice, _form.MinimumStock, _form.IsActive });
        }

        await LoadSeed();
        await Load();
        _showForm = false;
    }

    private async Task Toggle(ProductListItemDto item)
    {
        await Api.PostAsync($"api/commerce/products/{item.Id}/status", new { isActive = !item.IsActive });
        await Load();
    }

    private void NewVariant()
    {
        _variantForm = new ProductVariantUpsertCommand { ProductId = _form.Id, IsActive = true };
        _showVariantForm = true;
    }

    private async Task EditVariant(ProductVariantListItemDto item)
    {
        var detail = (await Api.GetAsync<AppResult<ProductVariantDetailDto>>($"api/commerce/product-variants/{item.Id}"))?.Data;
        if (detail is null) return;
        _variantForm = new ProductVariantUpsertCommand
        {
            Id = detail.Id,
            ProductId = detail.ProductId,
            Name = detail.Name,
            InternalCode = detail.InternalCode,
            Barcode = detail.Barcode,
            AttributesSummary = detail.AttributesSummary,
            Cost = detail.Cost,
            SalePrice = detail.SalePrice,
            IsActive = detail.IsActive
        };
        _showVariantForm = true;
    }

    private async Task SaveVariant()
    {
        if (_variantForm.Id == 0)
            await Api.PostAsync($"api/commerce/products/{_form.Id}/variants", new { ProductId = _form.Id, _variantForm.Name, _variantForm.InternalCode, _variantForm.Barcode, _variantForm.AttributesSummary, _variantForm.Cost, _variantForm.SalePrice, _variantForm.IsActive });
        else
            await Api.PutAsync($"api/commerce/product-variants/{_variantForm.Id}", new { _variantForm.Id, ProductId = _form.Id, _variantForm.Name, _variantForm.InternalCode, _variantForm.Barcode, _variantForm.AttributesSummary, _variantForm.Cost, _variantForm.SalePrice, _variantForm.IsActive });

        _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{_form.Id}/variants"))?.Data ?? new();
        _showVariantForm = false;
        await Load();
    }

    private async Task ToggleVariant(ProductVariantListItemDto item)
    {
        await Api.PostAsync($"api/commerce/product-variants/{item.Id}/status", new { isActive = !item.IsActive });
        _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{_form.Id}/variants"))?.Data ?? new();
        await Load();
    }

    private string UnitLabel(UnitOfMeasure unit) => unit switch
    {
        UnitOfMeasure.Unit => "Unidad",
        UnitOfMeasure.Kilogram => "Kg",
        UnitOfMeasure.Meter => "Metro",
        UnitOfMeasure.SquareMeter => "m²",
        UnitOfMeasure.CubicMeter => "m³",
        UnitOfMeasure.Liter => "Litro",
        UnitOfMeasure.Bag => "Bolsa",
        UnitOfMeasure.Bundle => "Bulto",
        _ => unit.ToString()
    };

    private void Cancel() { _showForm = false; _showVariantForm = false; }
    private void CancelVariant() => _showVariantForm = false;
}
