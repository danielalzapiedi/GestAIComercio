@page "/products"
@using GestAI.Web.Dtos
@inject ApiClient Api

<PageTitle>Productos</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Productos</div>
        <div class="page-hero-subtitle">Consolidá catálogo, precios, stock mínimo y variantes desde una pantalla más clara y consistente con el resto de Commerce.</div>
    </div>
    <div class="page-hero-meta">
        <span class="page-hero-chip"><i class="bi bi-box"></i> @TotalProducts productos</span>
        <span class="page-hero-chip"><i class="bi bi-diagram-3"></i> @_seed.Categories.Count categorías</span>
        <button class="btn btn-primary" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nuevo producto</button>
    </div>
</section>

<div class="row g-3 ui-summary-grid mb-1">
    <div class="col-sm-6 col-xl-3">
        <div class="card ui-stat-card"><div class="card-body">
            <div class="ui-stat-label">Catálogo</div>
            <div class="ui-stat-value">@TotalProducts</div>
            <div class="ui-stat-foot">Productos registrados en el listado actual.</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card ui-stat-card"><div class="card-body">
            <div class="ui-stat-label">Activos en página</div>
            <div class="ui-stat-value">@ActiveProductsOnPage</div>
            <div class="ui-stat-foot">Productos activos dentro del resultado visible.</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card ui-stat-card"><div class="card-body">
            <div class="ui-stat-label">Variantes visibles</div>
            <div class="ui-stat-value">@VisibleVariants</div>
            <div class="ui-stat-foot">Suma de variantes mostradas en esta página.</div>
        </div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card ui-stat-card"><div class="card-body">
            <div class="ui-stat-label">Filtro activo</div>
            <div class="ui-stat-value">@SelectedCategoryLabel</div>
            <div class="ui-stat-foot">@StatusFilterLabel</div>
        </div></div>
    </div>
</div>

<div class="card ui-filter-card"><div class="card-body">
    <div class="row g-2 align-items-end">
        <div class="col-lg-4"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Nombre, código, marca" /></div>
        <div class="col-md-4 col-lg-3"><label class="form-label">Categoría</label><select class="form-select" @bind="_selectedCategoryId"><option value="0">Todas</option>@foreach (var category in _seed.Categories){<option value="@category.Id">@category.Name</option>}</select></div>
        <div class="col-md-4 col-lg-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activos</option><option value="false">Inactivos</option></select></div>
        <div class="col-md-6 col-lg-1"><button class="btn btn-outline-primary w-100" @onclick="Search">Buscar</button></div>
        <div class="col-md-6 col-lg-2 text-md-end ui-table-meta">Catálogo comercial y operativo</div>
    </div>
</div></div>

<div class="ui-split-layout">
    <div>
        @if (!_loaded)
        {
            <div class="card"><div class="card-body">Cargando productos...</div></div>
        }
        else if (_result?.Items.Count == 0)
        {
            <EmptyState Title="No hay productos para mostrar"
                        Description="Creá el primer producto o ajustá los filtros para encontrarlo más rápido."
                        Icon="bi-box">
                <button class="btn btn-primary" @onclick="NewItem">Crear producto</button>
            </EmptyState>
        }
        else
        {
            <div class="card ui-data-card @(_showForm ? "d-none" : string.Empty)">
                <div class="card-body">
                    <div class="ui-card-header">
                        <div>
                            <div class="ui-card-eyebrow">Catálogo principal</div>
                            <h5 class="ui-card-title">Listado de productos</h5>
                            <div class="ui-card-subtitle">Vista preparada para revisar identidad comercial, precio, variantes y estado sin perder contexto.</div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Categoría</th>
                                    <th>Comercial</th>
                                    <th>Precio</th>
                                    <th>Variantes</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _result!.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="ui-product-main">
                                                <span class="ui-product-name">@item.Name</span>
                                                <span class="ui-product-meta">Código @item.InternalCode@(string.IsNullOrWhiteSpace(item.Barcode) ? string.Empty : $" · EAN {item.Barcode}")</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="ui-table-stack">
                                                <span class="fw-semibold">@item.CategoryName</span>
                                                <span class="ui-table-meta">Unidad @UnitLabel(item.UnitOfMeasure)</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="ui-table-stack">
                                                <span class="fw-semibold">@item.Brand</span>
                                                <span class="ui-table-meta">Marca comercial</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="ui-table-stack">
                                                <span class="fw-semibold">@item.SalePrice.ToString("C")</span>
                                                <span class="ui-table-meta">Precio de venta</span>
                                            </div>
                                        </td>
                                        <td><StatusBadge Text="@(item.VariantsCount == 0 ? "Sin variantes" : item.VariantsCount == 1 ? "1 variante" : $"{item.VariantsCount} variantes")" CssClass="@(item.VariantsCount > 0 ? "ui-badge ui-badge-primary" : "ui-badge ui-badge-neutral")" /></td>
                                        <td><StatusBadge IsActive="@item.IsActive" /></td>
                                        <td>
                                            <div class="ui-inline-actions">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(item)">Editar</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(item)">@(item.IsActive ? "Desactivar" : "Activar")</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="ui-action-bar">
                        <span class="text-muted">Página @_page de @TotalPages</span>
                        <div class="btn-group">
                            <button class="btn btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">Anterior</button>
                            <button class="btn btn-outline-secondary" disabled="@(_page >= TotalPages)" @onclick="NextPage">Siguiente</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="ui-section-grid">
        <div class="card">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Lectura rápida</div>
                        <h5 class="ui-card-title">Salud del catálogo</h5>
                        <div class="ui-card-subtitle">Indicadores simples para orientar revisión comercial y operativa.</div>
                    </div>
                </div>
                <div class="ui-list-stack">
                    <div class="ui-check-card"><i class="bi bi-check2-circle text-primary"></i><div><strong>Activos visibles</strong><div class="ui-table-meta">@ActiveProductsOnPage de @VisibleProductsInPage en esta página.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-boxes text-primary"></i><div><strong>Variantes visibles</strong><div class="ui-table-meta">@VisibleVariants asociadas a los productos listados.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-funnel text-primary"></i><div><strong>Filtro vigente</strong><div class="ui-table-meta">@SelectedCategoryLabel · @StatusFilterLabel.</div></div></div>
                </div>
            </div>
        </div>

        <div class="card ui-form-card @(_showForm ? "w-100 ui-editor-open" : "ui-editor-hidden")">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Editor de producto</div>
                        <h5 class="ui-card-title">@EditorTitle</h5>
                        <div class="ui-card-subtitle">@EditorSubtitle</div>
                    </div>
                </div>

                @if (!_showForm)
                {
                    <EmptyState Title="Seleccioná una acción"
                                Description="Podés crear un producto nuevo o editar uno existente desde la tabla principal."
                                Icon="bi-pencil-square">
                        <button class="btn btn-primary" @onclick="NewItem">Nuevo producto</button>
                    </EmptyState>
                }
                else
                {
                    <FormFeedback Error="@_error" Success="@_success" />
                    <div class="ui-form-section">
                        <div class="ui-form-section-title">Identidad comercial</div>
                        <div class="row g-3">
                            <div class="col-12"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" /></div>
                            <div class="col-md-6"><label class="form-label">Código interno</label><input class="form-control" @bind="_form.InternalCode" /></div>
                            <div class="col-md-6"><label class="form-label">Código de barras</label><input class="form-control" @bind="_form.Barcode" /></div>
                            <div class="col-12"><label class="form-label">Descripción</label><input class="form-control" @bind="_form.Description" placeholder="Describí el producto y su uso comercial" /></div>
                            <div class="col-md-6"><label class="form-label">Categoría</label><select class="form-select" @bind="_form.CategoryId">@foreach (var category in _seed.Categories){<option value="@category.Id">@category.Name</option>}</select></div>
                            <div class="col-md-6"><label class="form-label">Marca</label><input class="form-control" @bind="_form.Brand" list="brands-list" /></div>
                        </div>
                    </div>

                    <div class="ui-form-section">
                        <div class="ui-form-section-title">Precio y stock</div>
                        <div class="row g-3">
                            <div class="col-md-4"><label class="form-label">Unidad</label><select class="form-select" @bind="_form.UnitOfMeasure">@foreach (var unit in _seed.Units){<option value="@unit">@UnitLabel(unit)</option>}</select></div>
                            <div class="col-md-4"><label class="form-label">Costo</label><input class="form-control" type="number" step="0.01" @bind="_form.Cost" /></div>
                            <div class="col-md-4"><label class="form-label">Precio</label><input class="form-control" type="number" step="0.01" @bind="_form.SalePrice" /></div>
                            <div class="col-md-6"><label class="form-label">Stock mínimo</label><input class="form-control" type="number" step="0.01" @bind="_form.MinimumStock" /></div>
                            <div class="col-md-6"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" /><span>@(_form.IsActive ? "Producto activo" : "Producto inactivo")</span></div></div>
                        </div>
                    </div>

                    <datalist id="brands-list">@foreach (var brand in _seed.Brands){<option value="@brand"></option>}</datalist>

                    <div class="ui-action-bar">
                        <div class="ui-inline-actions">
                            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                            <button class="btn btn-outline-secondary" @onclick="Cancel" disabled="@_saving">Cancelar</button>
                        </div>
                        @if (_form.Id > 0)
                        {
                            <span class="ui-table-meta">Producto listo para administrar variantes.</span>
                        }
                    </div>

                    @if (_form.Id > 0)
                    {
                        <div class="ui-form-section">
                            <div class="ui-variant-head">
                                <div>
                                    <div class="ui-form-section-title mb-1">Variantes</div>
                                    <div class="ui-card-subtitle mt-0">Configurá combinaciones comerciales sin perder el contexto del producto base.</div>
                                </div>
                                <button class="btn btn-sm btn-outline-primary" @onclick="NewVariant">Nueva variante</button>
                            </div>

                            @if (_variants.Count == 0)
                            {
                                <EmptyState Title="Sin variantes cargadas"
                                            Description="Podés crear variantes para diferenciar atributos como color, medida o presentación."
                                            Icon="bi-boxes">
                                    <button class="btn btn-outline-primary" @onclick="NewVariant">Crear variante</button>
                                </EmptyState>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead><tr><th>Variante</th><th>Atributos</th><th>Precio</th><th>Estado</th><th></th></tr></thead>
                                        <tbody>
                                        @foreach (var variant in _variants)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="ui-product-main">
                                                        <span class="ui-product-name">@variant.Name</span>
                                                        <span class="ui-product-meta">Código @variant.InternalCode@(string.IsNullOrWhiteSpace(variant.Barcode) ? string.Empty : $" · EAN {variant.Barcode}")</span>
                                                    </div>
                                                </td>
                                                <td>@variant.AttributesSummary</td>
                                                <td>@variant.SalePrice.ToString("C")</td>
                                                <td><StatusBadge IsActive="@variant.IsActive" /></td>
                                                <td>
                                                    <div class="ui-inline-actions">
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditVariant(variant)">Editar</button>
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleVariant(variant)">@(variant.IsActive ? "Desactivar" : "Activar")</button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (_showVariantForm)
                            {
                                <div class="ui-variant-panel">
                                    <div class="ui-card-header mb-0">
                                        <div>
                                            <div class="ui-card-eyebrow">Editor de variante</div>
                                            <h6 class="ui-card-title">@(_variantForm.Id == 0 ? "Nueva variante" : "Editar variante")</h6>
                                            <div class="ui-card-subtitle">Completá identidad, atributos y precio de la variante.</div>
                                        </div>
                                    </div>
                                    <div class="row g-3 mt-1">
                                        <div class="col-md-6"><label class="form-label">Nombre</label><input class="form-control" @bind="_variantForm.Name" /></div>
                                        <div class="col-md-6"><label class="form-label">Atributos</label><input class="form-control" @bind="_variantForm.AttributesSummary" placeholder="Ej: Color rojo / 2m" /></div>
                                        <div class="col-md-6"><label class="form-label">Código interno</label><input class="form-control" @bind="_variantForm.InternalCode" /></div>
                                        <div class="col-md-6"><label class="form-label">Código de barras</label><input class="form-control" @bind="_variantForm.Barcode" /></div>
                                        <div class="col-md-4"><label class="form-label">Costo</label><input class="form-control" type="number" step="0.01" @bind="_variantForm.Cost" /></div>
                                        <div class="col-md-4"><label class="form-label">Precio</label><input class="form-control" type="number" step="0.01" @bind="_variantForm.SalePrice" /></div>
                                        <div class="col-md-4"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_variantForm.IsActive" /><span>@(_variantForm.IsActive ? "Variante activa" : "Variante inactiva")</span></div></div>
                                    </div>
                                    <div class="ui-action-bar">
                                        <div class="ui-inline-actions">
                                            <button class="btn btn-primary btn-sm" @onclick="SaveVariant" disabled="@_saving">Guardar variante</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelVariant" disabled="@_saving">Cancelar</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private PagedResult<ProductListItemDto>? _result;
    private ProductSeedDataDto _seed = new(new List<LookupDto>(), new List<string>(), Array.Empty<UnitOfMeasure>());
    private List<ProductVariantListItemDto> _variants = new();
    private string _search = string.Empty;
    private int _selectedCategoryId;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _showForm;
    private bool _showVariantForm;
    private int _page = 1;
    private const int PageSize = 10;
    private ProductUpsertCommand _form = new();
    private ProductVariantUpsertCommand _variantForm = new();
    private bool _saving;
    private string? _error;
    private string? _success;

    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);
    private int TotalProducts => _result?.TotalCount ?? 0;
    private int VisibleProductsInPage => _result?.Items.Count ?? 0;
    private int VisibleVariants => _result?.Items.Sum(x => x.VariantsCount) ?? 0;
    private int ActiveProductsOnPage => _result?.Items.Count(x => x.IsActive) ?? 0;
    private string SelectedCategoryLabel => _selectedCategoryId > 0
        ? _seed.Categories.FirstOrDefault(x => x.Id == _selectedCategoryId)?.Name ?? "Categoría filtrada"
        : "Todas las categorías";
    private string StatusFilterLabel => string.IsNullOrWhiteSpace(_status)
        ? "Sin filtro de estado"
        : _status == "true"
            ? "Sólo activos"
            : "Sólo inactivos";
    private string EditorTitle => _form.Id == 0 ? "Nuevo producto" : "Editar producto";
    private string EditorSubtitle => _form.Id == 0
        ? "Definí identidad comercial, precio y stock mínimo del producto base."
        : "Actualizá datos del producto y administrá sus variantes desde el mismo panel.";

    protected override async Task OnInitializedAsync()
    {
        await LoadSeed();
        await Load();
    }

    private async Task LoadSeed()
    {
        _seed = (await Api.GetAsync<AppResult<ProductSeedDataDto>>("api/commerce/products/seed"))?.Data ?? new ProductSeedDataDto(new List<LookupDto>(), new List<string>(), Enum.GetValues<UnitOfMeasure>());
    }

    private async Task Search() { _page = 1; await Load(); }

    private async Task Load()
    {
        _loaded = false;
        var category = _selectedCategoryId > 0 ? $"&categoryId={_selectedCategoryId}" : string.Empty;
        var active = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
        _result = (await Api.GetAsync<AppResult<PagedResult<ProductListItemDto>>>($"api/commerce/products?search={Uri.EscapeDataString(_search ?? string.Empty)}{category}{active}&page={_page}&pageSize={PageSize}"))?.Data;
        _loaded = true;
    }

    private void NewItem()
    {
        _error = null;
        _success = null;
        _form = new ProductUpsertCommand { IsActive = true, UnitOfMeasure = UnitOfMeasure.Unit, CategoryId = _seed.Categories.FirstOrDefault()?.Id ?? 0 };
        _variantForm = new ProductVariantUpsertCommand();
        _variants = new();
        _showVariantForm = false;
        _showForm = true;
    }

    private async Task Edit(ProductListItemDto item)
    {
        _error = null;
        _success = null;
        var detail = (await Api.GetAsync<AppResult<ProductDetailDto>>($"api/commerce/products/{item.Id}"))?.Data;
        if (detail is null) return;
        _form = new ProductUpsertCommand
        {
            Id = detail.Id,
            Name = detail.Name,
            InternalCode = detail.InternalCode,
            Barcode = detail.Barcode,
            Description = detail.Description,
            CategoryId = detail.CategoryId,
            Brand = detail.Brand,
            UnitOfMeasure = detail.UnitOfMeasure,
            Cost = detail.Cost,
            SalePrice = detail.SalePrice,
            MinimumStock = detail.MinimumStock,
            IsActive = detail.IsActive
        };
        _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{item.Id}/variants"))?.Data ?? new();
        _showVariantForm = false;
        _showForm = true;
    }

    private async Task Save()
    {
        _error = null;
        _success = null;
        _saving = true;
        try
        {
            if (_form.Id == 0)
            {
                var response = await Api.PostAsync<object, AppResult<int>>("api/commerce/products", new { _form.Name, _form.InternalCode, _form.Barcode, _form.Description, _form.CategoryId, _form.Brand, _form.UnitOfMeasure, _form.Cost, _form.SalePrice, _form.MinimumStock, _form.IsActive });
                if (response?.Data is int productId)
                {
                    _form.Id = productId;
                    _variants = new();
                }
            }
            else
            {
                await Api.PutAsync($"api/commerce/products/{_form.Id}", new { _form.Id, _form.Name, _form.InternalCode, _form.Barcode, _form.Description, _form.CategoryId, _form.Brand, _form.UnitOfMeasure, _form.Cost, _form.SalePrice, _form.MinimumStock, _form.IsActive });
            }

            await LoadSeed();
            await Load();

            if (_form.Id > 0)
            {
                _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{_form.Id}/variants"))?.Data ?? new();
                _showForm = true;
            }
            else
            {
                _showForm = false;
            }

            _showVariantForm = false;
            _success = "Producto guardado correctamente.";
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(ProductListItemDto item)
    {
        _error = null;
        _success = null;
        try
        {
            await Api.PostAsync($"api/commerce/products/{item.Id}/status", new { isActive = !item.IsActive });
            _success = item.IsActive ? "Producto desactivado." : "Producto activado.";
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private void NewVariant()
    {
        _variantForm = new ProductVariantUpsertCommand { ProductId = _form.Id, IsActive = true };
        _showVariantForm = true;
    }

    private async Task EditVariant(ProductVariantListItemDto item)
    {
        var detail = (await Api.GetAsync<AppResult<ProductVariantDetailDto>>($"api/commerce/product-variants/{item.Id}"))?.Data;
        if (detail is null) return;
        _variantForm = new ProductVariantUpsertCommand
        {
            Id = detail.Id,
            ProductId = detail.ProductId,
            Name = detail.Name,
            InternalCode = detail.InternalCode,
            Barcode = detail.Barcode,
            AttributesSummary = detail.AttributesSummary,
            Cost = detail.Cost,
            SalePrice = detail.SalePrice,
            IsActive = detail.IsActive
        };
        _showVariantForm = true;
    }

    private async Task SaveVariant()
    {
        _error = null;
        _success = null;
        try
        {
            if (_variantForm.Id == 0)
                await Api.PostAsync($"api/commerce/products/{_form.Id}/variants", new { ProductId = _form.Id, _variantForm.Name, _variantForm.InternalCode, _variantForm.Barcode, _variantForm.AttributesSummary, _variantForm.Cost, _variantForm.SalePrice, _variantForm.IsActive });
            else
                await Api.PutAsync($"api/commerce/product-variants/{_variantForm.Id}", new { _variantForm.Id, ProductId = _form.Id, _variantForm.Name, _variantForm.InternalCode, _variantForm.Barcode, _variantForm.AttributesSummary, _variantForm.Cost, _variantForm.SalePrice, _variantForm.IsActive });

            _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{_form.Id}/variants"))?.Data ?? new();
            _showVariantForm = false;
            _success = "Variante guardada correctamente.";
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ToggleVariant(ProductVariantListItemDto item)
    {
        _error = null;
        _success = null;
        try
        {
            await Api.PostAsync($"api/commerce/product-variants/{item.Id}/status", new { isActive = !item.IsActive });
            _variants = (await Api.GetAsync<AppResult<List<ProductVariantListItemDto>>>($"api/commerce/products/{_form.Id}/variants"))?.Data ?? new();
            _success = item.IsActive ? "Variante desactivada." : "Variante activada.";
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private string UnitLabel(UnitOfMeasure unit) => unit switch
    {
        UnitOfMeasure.Unit => "Unidad",
        UnitOfMeasure.Kilogram => "Kg",
        UnitOfMeasure.Meter => "Metro",
        UnitOfMeasure.SquareMeter => "m²",
        UnitOfMeasure.CubicMeter => "m³",
        UnitOfMeasure.Liter => "Litro",
        UnitOfMeasure.Bag => "Bolsa",
        UnitOfMeasure.Bundle => "Bulto",
        _ => unit.ToString()
    };

    private void Cancel()
    {
        _showForm = false;
        _showVariantForm = false;
        _variants = new();
        _variantForm = new ProductVariantUpsertCommand();
        _form = new ProductUpsertCommand();
    }

    private void CancelVariant() => _showVariantForm = false;
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }
}
