@page "/sales"
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@using System.Text.Json
@inject ApiClient Api
@inject GestAI.Web.Service.CommerceFormValidator FormValidator
@inject NavigationManager Navigation
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject IJSRuntime JS

<PageTitle>Ventas</PageTitle>

<ListPageHeader Title="Ventas"
                Subtitle="Registrá ventas simples pero con base correcta para crecer hacia comprobantes y cobranzas futuras."
                ChipText="@($"{_result?.TotalCount ?? 0} ventas")"
                ChipIconClass="bi bi-receipt-cutoff">
    <Actions>
        @if (_showForm)
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="BackToList"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <a class="btn btn-outline-secondary" href="/sales/quick"><i class="bi bi-lightning-charge me-2"></i>Carga rápida</a>
            <button class="btn btn-primary" type="button" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nueva venta</button>
        }
    </Actions>
</ListPageHeader>

@if (!_showForm)
{
    <div class="row g-3 ui-summary-grid mb-1">
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Total visible</div><div class="ui-stat-value">@VisibleTotal.ToString("C")</div><div class="ui-stat-foot">Importe acumulado de la página.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Con origen</div><div class="ui-stat-value">@SalesWithSourceQuote</div><div class="ui-stat-foot">Ventas que nacieron desde un presupuesto.</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Cliente filtro</div><div class="ui-stat-value">@SelectedCustomerLabel</div><div class="ui-stat-foot">@StatusFilterLabel</div></div></div></div>
        <div class="col-sm-6 col-xl-3"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">SKUs</div><div class="ui-stat-value">@_skuIndex.Count</div><div class="ui-stat-foot">Productos y variantes disponibles para venta.</div></div></div></div>
    </div>
}

@if (!_showForm)
{
    <ListPageFilters>
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Número, cliente, presupuesto origen" /></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Cliente</label><select class="form-select" @bind="_customerId"><option value="0">Todos</option>@foreach (var customer in _seed.Customers){<option value="@customer.Id">@customer.Name</option>}</select></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option>@foreach (var status in Enum.GetValues<SaleStatus>()){<option value="@status">@SaleStatusLabel(status)</option>}</select></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-primary w-100" type="button" @onclick="Search">Buscar</button></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-secondary w-100" type="button" @onclick="ClearFilters">Limpiar</button></div>
        </div>
    </ListPageFilters>
    <FormFeedback Error="@_loadError" />
}

<div class="ui-split-layout ui-split-layout-focus-editor">
    <div class="@(_showForm ? "d-none" : string.Empty)">
        @if (!_loaded)
        {
            <div class="card"><div class="card-body">Cargando ventas...</div></div>
        }
        else if (_result?.Items.Count == 0 && !_showForm)
        {
            <EmptyState Title="No hay ventas"
                        Description="Podés registrar una venta manual o entrar por carga rápida para acelerar la operación."
                        Icon="bi-receipt-cutoff">
                <button class="btn btn-primary" type="button" @onclick="NewItem">Crear venta</button>
            </EmptyState>
        }
        else
        {
            @if (_result?.Items.Count == 0)
            {
                <EmptyState Title="Todavía no hay ventas cargadas"
                            Description="Podés empezar la primera venta desde el editor lateral sin salir de esta pantalla."
                            Icon="bi-receipt-cutoff">
                    <button class="btn btn-primary" type="button" @onclick="NewItem">Nueva venta</button>
                </EmptyState>
            }
            else
            {
                <div class="card ui-data-card @(_showForm ? "d-none" : string.Empty)"><div class="card-body">
                    <div class="ui-card-header"><div><div class="ui-card-eyebrow">Circuito comercial</div><h5 class="ui-card-title">Listado de ventas</h5><div class="ui-card-subtitle">Cliente, origen y estado en una sola vista operativa.</div></div></div>
                    <UnifiedGrid ActionsDropdown="true">
                            <thead><tr><th>Comprobante</th><th>Cliente</th><th>Fecha</th><th>Origen</th><th>Total</th><th>Estado</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var item in _result!.Items)
                            {
                                <tr>
                                    <td><div class="ui-table-stack"><span class="fw-semibold">@item.Number</span><span class="ui-table-meta">@((item.ItemsCount == 1 ? "1 ítem" : $"{item.ItemsCount} ítems"))</span></div></td>
                                    <td>@item.CustomerName</td>
                                    <td>@item.IssuedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td>@(item.SourceQuoteId.HasValue ? item.SourceQuoteNumber : "Manual")</td>
                                    <td><div class="ui-table-stack"><span class="fw-semibold">@item.Total.ToString("C")</span><span class="ui-table-meta">Subtotal @item.Subtotal.ToString("C")</span></div></td>
                                    <td><StatusBadge Text="@SaleStatusLabel(item.Status)" CssClass="@SaleStatusClass(item.Status)" /></td>
                                    <td class="text-end">
                                        <div class="dropdown dropstart table-actions">
                                            <button class="ui-kebab-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Acciones">
                                                <i class="bi bi-three-dots-vertical"></i>
                                                <span class="visually-hidden">Acciones</span>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end ui-actions-menu">
                                                <li><button class="dropdown-item" type="button" @onclick="() => Edit(item.Id)"><i class="bi bi-pencil-square me-2"></i>Editar</button></li>
                                                <li><button class="dropdown-item" type="button" @onclick="() => OpenDetail(item.Id)"><i class="bi bi-eye me-2"></i>Detalle</button></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </UnifiedGrid>
                    <ListPaginationBar Page="@_page" TotalPages="@TotalPages" OnPrevious="PrevPage" OnNext="NextPage" />
                </div></div>
            }
        }
    </div>

    <div class="ui-section-grid @(_showForm ? "w-100" : string.Empty)">
        <div class="card ui-form-card @(_showForm ? "w-100 ui-editor-open" : "ui-editor-hidden")" id="sales-editor"><div class="card-body">
            <div class="ui-card-header"><div><div class="ui-card-eyebrow">Carga guiada</div><h5 class="ui-card-title">@(_form.Id == 0 ? "Nueva venta" : $"Editar {_editingNumber}")</h5><div class="ui-card-subtitle">Completá cliente, fecha e ítems en un solo panel visible desde el primer click.</div></div></div>
            @if (!_showForm)
            {
                <EmptyState Title="Seleccioná una acción"
                            Description="Usá Nueva venta para abrir el formulario listo para completar, o editá una operación existente desde la tabla."
                            Icon="bi-pencil-square">
                    <button class="btn btn-primary" type="button" @onclick="NewItem">Nueva venta</button>
                </EmptyState>
            }
            else
            {
                <FormFeedback Error="@_error" Success="@_success" />
                    <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@(IsDirty)" />
                <div class="ui-form-section">
                    <div class="ui-form-section-title">Cabecera</div>
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Cliente</label><select class="form-select" @bind="_form.CustomerId"><option value="0">Seleccionar cliente</option>@foreach (var customer in _seed.Customers){<option value="@customer.Id">@customer.Name</option>}</select></div>
                        <div class="col-md-3"><label class="form-label">Fecha</label><input class="form-control" type="date" @bind-value="_issuedAtDate" /></div>
                        <div class="col-md-3"><label class="form-label">Estado</label><select class="form-select" @bind="_form.Status">@foreach (var status in Enum.GetValues<SaleStatus>()){<option value="@status">@SaleStatusLabel(status)</option>}</select></div>
                        <div class="col-12"><label class="form-label">Observaciones</label><input class="form-control" @bind="_form.Observations" placeholder="Condiciones, canal, referencia interna" /></div>
                    </div>
                </div>
                <div class="ui-form-section">
                    <div class="ui-variant-head"><div><div class="ui-form-section-title mb-1">Ítems</div><div class="ui-card-subtitle mt-0">Búsqueda por nombre o código y edición rápida de cantidades/precios.</div><div class="ui-table-meta">@PricingPolicy.StandardSalePolicyDescription</div></div><button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddBlankLine">Agregar línea</button></div>
                    <div class="row g-2 mb-3">
                        <div class="col-12"><label class="form-label">Búsqueda rápida</label><input class="form-control" @bind="_quickSearch" placeholder="Buscar por nombre o código" /></div>
                        @if (QuickMatches.Count > 0)
                        {
                            <div class="col-12"><div class="list-group ui-search-list">@foreach (var sku in QuickMatches){<button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => AddSku(sku)"><span><strong>@sku.Label</strong><span class="ui-table-meta ms-2">@sku.InternalCode</span></span><span>@sku.SalePrice.ToString("C")</span></button>}</div></div>
                        }
                    </div>
                    @if (_form.Items.Count == 0)
                    {
                        <EmptyState Title="Sin líneas cargadas" Description="Agregá productos para registrar la venta." Icon="bi-card-list"><button class="btn btn-outline-primary" type="button" @onclick="AddBlankLine">Agregar línea</button></EmptyState>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead><tr><th>Descripción</th><th>Código</th><th>Cantidad</th><th>Precio</th><th>Subtotal</th><th></th></tr></thead>
                                <tbody>
                                @for (var i = 0; i < _form.Items.Count; i++)
                                {
                                    var line = _form.Items[i];
                                    <tr>
                                        <td><input class="form-control" @bind="line.Description" /></td>
                                        <td><input class="form-control" @bind="line.InternalCode" /></td>
                                        <td><input class="form-control" type="number" step="0.01" @bind="line.Quantity" /></td>
                                        <td><input class="form-control" type="number" step="0.01" @bind="line.UnitPrice" /></td>
                                        <td class="fw-semibold">@line.LineSubtotal.ToString("C")</td>
                                        <td><button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => RemoveLine(i)" title="Quitar línea" aria-label="Quitar línea"><i class="bi bi-trash"></i></button></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="ui-action-bar"><div class="ui-inline-actions"><button class="btn btn-primary" type="button" @onclick="Save" disabled="@_saving">Guardar</button><button class="btn btn-outline-secondary" type="button" @onclick="Cancel" disabled="@_saving">Cancelar</button></div><div class="ui-table-stack text-end"><span class="fw-semibold">Total @FormTotal.ToString("C")</span><span class="ui-table-meta">@(_form.Items.Count == 1 ? "1 ítem" : $"{_form.Items.Count} ítems")</span><span class="ui-table-meta">@((IsDirty) ? "Cambios sin guardar" : "Sin cambios pendientes")</span></div></div>
            }
        </div></div>

        <div class="card">
            <div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Ayuda rápida</div><h5 class="ui-card-title">Cómo cargar una venta</h5><div class="ui-card-subtitle">La guía queda debajo para no tapar la acción principal.</div></div></div>
                <div class="ui-list-stack">
                    <div class="ui-check-card"><i class="bi bi-1-circle text-primary"></i><div><strong>Elegí el cliente</strong><div class="ui-table-meta">Podés dejar la venta en borrador y completarla más tarde.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-2-circle text-primary"></i><div><strong>Completá los ítems</strong><div class="ui-table-meta">La venta nueva ya abre con una línea lista para editar.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-3-circle text-primary"></i><div><strong>Guardá o seguí por carga rápida</strong><div class="ui-table-meta">Si necesitás velocidad, la carga rápida sigue disponible desde el botón superior.</div></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private PagedResult<SaleListItemDto>? _result;
    private CommercialDocumentSeedDataDto _seed = new(Array.Empty<LookupDto>(), Array.Empty<CommercialSkuLookupDto>(), Array.Empty<CommercialSkuLookupDto>());
    private readonly List<CommercialSkuLookupDto> _skuIndex = new();
    private SaleUpsertCommand _form = new();
    private bool _loaded;
    private bool _showForm;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private string _quickSearch = string.Empty;
    private int _customerId;
    private int _page = 1;
    private const int PageSize = 10;
    private string _editingNumber = string.Empty;
    private DateTime _issuedAtDate = DateTime.UtcNow.Date;
    private bool _saving;
    private string? _error;
    private string? _success;
    private string? _loadError;
    private string _formSnapshot = string.Empty;

    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);
    private decimal VisibleTotal => _result?.Items.Sum(x => x.Total) ?? 0m;
    private int SalesWithSourceQuote => _result?.Items.Count(x => x.SourceQuoteId.HasValue) ?? 0;
    private string SelectedCustomerLabel => _customerId == 0 ? "Todos" : _seed.Customers.FirstOrDefault(x => x.Id == _customerId)?.Name ?? "Cliente";
    private string StatusFilterLabel => string.IsNullOrWhiteSpace(_status) ? "Sin filtro de estado" : SaleStatusLabel(Enum.Parse<SaleStatus>(_status));
    private decimal FormTotal => _form.Items.Sum(x => x.LineSubtotal);
    private List<CommercialSkuLookupDto> QuickMatches => string.IsNullOrWhiteSpace(_quickSearch) ? new() : _skuIndex.Where(x => x.IsActive && (x.Label.Contains(_quickSearch, StringComparison.OrdinalIgnoreCase) || x.InternalCode.Contains(_quickSearch, StringComparison.OrdinalIgnoreCase))).Take(6).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadSeed();
        await Load();
    }

    private async Task LoadSeed()
    {
        _seed = (await Api.GetAsync<AppResult<CommercialDocumentSeedDataDto>>("api/commerce/commercial/seed"))?.Data ?? new CommercialDocumentSeedDataDto(Array.Empty<LookupDto>(), Array.Empty<CommercialSkuLookupDto>(), Array.Empty<CommercialSkuLookupDto>());
        _skuIndex.Clear();
        _skuIndex.AddRange(_seed.Products);
        _skuIndex.AddRange(_seed.Variants);
    }

    private async Task Load()
    {
        _loaded = false;
        _loadError = null;
        try
        {
            var status = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&status={_status}";
            var customer = _customerId == 0 ? string.Empty : $"&customerId={_customerId}";
            _result = (await Api.GetAsync<AppResult<PagedResult<SaleListItemDto>>>($"api/commerce/sales?search={Uri.EscapeDataString(_search ?? string.Empty)}{status}{customer}&page={_page}&pageSize={PageSize}"))?.Data;
            _result ??= new PagedResult<SaleListItemDto>(new List<SaleListItemDto>(), 0, _page, PageSize);
        }
        catch (ApiClient.ApiClientException ex)
        {
            _loadError = ex.Message;
            Telemetry.Track("sales", "load", "error", ex.Message);
            _result = null;
        }
        _loaded = true;
    }

    private async Task Search()
    {
        _page = 1;
        await Load();
        Telemetry.Track("sales", "search", "success");
    }

    private async Task ClearFilters()
    {
        _search = string.Empty;
        _status = string.Empty;
        _customerId = 0;
        _page = 1;
        await Load();
        Telemetry.Track("sales", "clear-filters", "success");
    }

    private void NewItem()
    {
        _error = null;
        _success = null;
        _form = new SaleUpsertCommand
        {
            Status = SaleStatus.Draft,
            IssuedAtUtc = DateTime.UtcNow,
            Items = new List<CommercialLineFormModel>
            {
                new() { Quantity = 1 }
            }
        };
        _issuedAtDate = DateTime.UtcNow.Date;
        _quickSearch = string.Empty;
        _editingNumber = "borrador";
        _showForm = true;
        MarkClean();
    }

    private async Task Edit(int id)
    {
        _error = null;
        _success = null;
        var detail = (await Api.GetAsync<AppResult<SaleDetailDto>>($"api/commerce/sales/{id}"))?.Data;
        if (detail is null) return;
        _form = new SaleUpsertCommand
        {
            Id = detail.Id,
            CustomerId = detail.CustomerId,
            Status = detail.Status,
            IssuedAtUtc = detail.IssuedAtUtc,
            Observations = detail.Observations,
            Items = detail.Items.Select(x => new CommercialLineFormModel { ProductId = x.ProductId, ProductVariantId = x.ProductVariantId, Description = x.Description, InternalCode = x.InternalCode, Quantity = x.Quantity, UnitPrice = x.UnitPrice }).ToList()
        };
        _issuedAtDate = detail.IssuedAtUtc;
        _editingNumber = detail.Number;
        _showForm = true;
        MarkClean();
    }

    private async Task Save()
    {
        _error = null;
        _success = null;
        var validation = ValidateEditor();
        if (validation.Count > 0)
        {
            _error = string.Join(" ", validation);
            Telemetry.Track("sales", "validate", "error", string.Join(" | ", validation));
            return;
        }
        _saving = true;
        try
        {
            _form.IssuedAtUtc = _issuedAtDate;
            var body = new
            {
                _form.Id,
                _form.CustomerId,
                _form.Status,
                _form.IssuedAtUtc,
                _form.Observations,
                Items = _form.Items.Select((x, idx) => new { x.ProductId, x.ProductVariantId, x.Description, x.Quantity, x.UnitPrice, SortOrder = idx + 1 }).ToList()
            };
            if (_form.Id == 0)
                await Api.PostAsync("api/commerce/sales", body);
            else
                await Api.PutAsync($"api/commerce/sales/{_form.Id}", body);
            _showForm = false;
            _success = "Venta guardada correctamente.";
            Telemetry.Track("sales", "save", "success", _form.Id == 0 ? "create" : "update");
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            Telemetry.Track("sales", "save", "error", ex.Message);
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void AddBlankLine() => _form.Items.Add(new CommercialLineFormModel { Quantity = 1 });
    private void AddSku(CommercialSkuLookupDto sku)
    {
        _form.Items.Add(new CommercialLineFormModel
        {
            ProductId = sku.ProductId,
            ProductVariantId = sku.ProductVariantId,
            Description = sku.Label,
            InternalCode = sku.InternalCode,
            Quantity = 1,
            UnitPrice = PricingPolicy.ResolvePrice(PricingPolicy.StandardSaleMode, sku.SalePrice)
        });
        _quickSearch = string.Empty;
    }
    private void RemoveLine(int index) { if (index >= 0 && index < _form.Items.Count) _form.Items.RemoveAt(index); }
    private async Task Cancel()
    {
        if (!await ConfirmDiscardIfDirtyAsync())
            return;
        _showForm = false;
    }
    private async Task BackToList()
    {
        if (!await ConfirmDiscardIfDirtyAsync())
            return;
        _showForm = false;
    }
    private void OpenDetail(int id) => Navigation.NavigateTo($"/sales/{id}");
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }

    private static string SaleStatusLabel(SaleStatus status) => status switch
    {
        SaleStatus.Draft => "Borrador",
        SaleStatus.Confirmed => "Confirmada",
        SaleStatus.Completed => "Completada",
        SaleStatus.Cancelled => "Cancelada",
        _ => status.ToString()
    };

    private static string SaleStatusClass(SaleStatus status) => status switch
    {
        SaleStatus.Completed => "ui-badge ui-badge-success",
        SaleStatus.Confirmed => "ui-badge ui-badge-primary",
        SaleStatus.Cancelled => "ui-badge ui-badge-danger",
        _ => "ui-badge ui-badge-neutral"
    };

}
