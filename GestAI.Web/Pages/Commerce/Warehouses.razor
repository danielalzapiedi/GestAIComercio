@page "/warehouses"
@using Microsoft.AspNetCore.Components.Routing
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@inject ApiClient Api
@inject IJSRuntime JS
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject CommerceMasterUiService Ui

<PageTitle>Depósitos</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Depósitos</div>
        <div class="page-hero-subtitle">Gestioná depósitos por sucursal y definí cuál es el principal de cada una.</div>
    </div>
    <div class="page-hero-meta">
        @if (_showForm)
        {
            <button class="btn btn-outline-secondary" @onclick="Cancel"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <span class="page-hero-chip"><i class="bi bi-box-seam"></i> @(_result?.TotalCount ?? 0) depósitos</span>
            <button class="btn btn-primary" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nuevo depósito</button>
        }
    </div>
</section>

<div class="card ui-filter-card"><div class="card-body">
    <div class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label">Sucursal</label><select class="form-select" @bind="_selectedBranchId"><option value="0">Todas</option>@foreach (var branch in _branches){<option value="@branch.Id">@branch.Name</option>}</select></div>
        <div class="col-md-3"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Nombre" /></div>
        <div class="col-md-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activos</option><option value="false">Inactivos</option></select></div>
        <div class="col-md-2"><button class="btn btn-outline-primary w-100" @onclick="Search">Buscar</button></div>
        <div class="col-md-1"><button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Limpiar</button></div>
    </div>
</div></div>

@if (!_loaded)
{
    <div class="card"><div class="card-body">Cargando depósitos...</div></div>
}
else if (_result?.Items.Count == 0)
{
    <FormFeedback Error="@_error" Success="@_success" />
    <EmptyState Title="No hay depósitos para mostrar"
                Description="Creá depósitos para organizar stock y operación por sucursal."
                Icon="bi-box-seam">
        <button class="btn btn-primary" @onclick="NewItem">Crear depósito</button>
    </EmptyState>
}
else
{
    <NavigationLock ConfirmExternalNavigation="@(_showForm && _isDirty)" OnBeforeInternalNavigation="@ConfirmInternalNavigation" />
    <FormFeedback Error="@_error" Success="@_success" />
    <div class="ui-split-layout">
        <div class="card ui-data-card @(_showForm ? "d-none" : string.Empty)">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Operación logística</div>
                        <h5 class="ui-card-title">Listado de depósitos</h5>
                        <div class="ui-card-subtitle">Sucursal, indicador principal y estado de cada depósito.</div>
                    </div>
                </div>
                <div class="table-responsive">
                <table class="table table-striped">
                    <thead><tr><th>Nombre</th><th>Sucursal</th><th>Principal</th><th>Estado</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var item in _result!.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.BranchName</td>
                            <td><StatusBadge Text="@(item.IsMain ? "Principal" : "Secundario")" CssClass="@(item.IsMain ? "ui-badge ui-badge-primary" : "ui-badge ui-badge-neutral")" /></td>
                            <td><StatusBadge IsActive="@item.IsActive" /></td>
                            <td>
                                <div class="ui-inline-actions">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(item)">Editar</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => Toggle(item)">@(item.IsActive ? "Desactivar" : "Activar")</button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
                </div>
                <div class="ui-action-bar">
                    <span class="text-muted">Página @_page de @TotalPages</span>
                    <div class="btn-group">
                        <button class="btn btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">Anterior</button>
                        <button class="btn btn-outline-secondary" disabled="@(_page >= TotalPages)" @onclick="NextPage">Siguiente</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card ui-form-card @(_showForm ? "w-100 ui-editor-open" : "ui-editor-hidden")">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Editor</div>
                        <h5 class="ui-card-title">@(_showForm ? (_form.Id == 0 ? "Nuevo depósito" : "Editar depósito") : "Detalle y edición")</h5>
                        <div class="ui-card-subtitle">Definí sucursal, nombre y configuración principal.</div>
                    </div>
                </div>

                @if (!_showForm)
                {
                    <EmptyState Title="Seleccioná una acción"
                                Description="Creá un depósito nuevo o editá uno existente desde la tabla."
                                Icon="bi-pencil-square">
                        <button class="btn btn-primary" @onclick="NewItem">Nuevo depósito</button>
                    </EmptyState>
                }
                else
                {
                    <FormFeedback Error="@_error" Success="@_success" />
                    <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@_isDirty" />
                    <div class="row g-3">
                        <div class="col-12"><label class="form-label">Sucursal</label><select class="form-select" @bind="_form.BranchId" @bind:after="MarkDirty">@foreach (var branch in _branches){<option value="@branch.Id">@branch.Name</option>}</select></div>
                        <div class="col-12"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" @bind:after="MarkDirty" /></div>
                        <div class="col-md-6"><label class="form-label d-block">Rol del depósito</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsMain" @bind:after="MarkDirty" /><span>@(_form.IsMain ? "Depósito principal" : "Depósito secundario")</span></div></div>
                        <div class="col-md-6"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" @bind:after="MarkDirty" /><span>@(_form.IsActive ? "Depósito activo" : "Depósito inactivo")</span></div></div>
                    </div>
                    <div class="ui-action-bar">
                        <div class="ui-inline-actions">
                            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                            <button class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<WarehouseListItemDto>? _result;
    private List<LookupDto> _branches = new();
    private int _selectedBranchId;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _showForm;
    private bool _saving;
    private bool _isDirty;
    private int _page = 1;
    private const int PageSize = 10;
    private WarehouseUpsertCommand _form = new();
    private string? _error;
    private string? _success;

    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
        await Load();
    }

    private async Task LoadBranches()
    {
        try
        {
            _error = null;
            _success = null;
            _branches = (await Api.GetAsync<AppResult<PagedResult<BranchListItemDto>>>("api/commerce/branches?pageSize=100"))?.Data?.Items.Select(x => new LookupDto(x.Id, x.Name)).ToList() ?? new();
            Telemetry.Track("warehouses", "load-branches", "success");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("warehouses", "load-branches", "error", ex.Message);
            _branches = new();
        }
    }

    private async Task Search()
    {
        _page = 1;
        await Load();
        Telemetry.Track("warehouses", "search", "success");
    }

    private async Task ClearFilters()
    {
        _selectedBranchId = 0;
        _search = string.Empty;
        _status = string.Empty;
        _page = 1;
        await Load();
        Telemetry.Track("warehouses", "clear-filters", "success");
    }

    private async Task Load()
    {
        _loaded = false;
        try
        {
            _error = null;
            var branch = _selectedBranchId > 0 ? $"branchId={_selectedBranchId}&" : string.Empty;
            var active = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
            _result = (await Api.GetAsync<AppResult<PagedResult<WarehouseListItemDto>>>($"api/commerce/warehouses?{branch}search={Uri.EscapeDataString(_search ?? string.Empty)}{active}&page={_page}&pageSize={PageSize}"))?.Data;
            _result ??= new PagedResult<WarehouseListItemDto>(new List<WarehouseListItemDto>(), 0, _page, PageSize);
            Telemetry.Track("warehouses", "load", "success");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("warehouses", "load", "error", ex.Message);
            _result = new PagedResult<WarehouseListItemDto>(new List<WarehouseListItemDto>(), 0, _page, PageSize);
        }
        _loaded = true;
    }

    private void NewItem()
    {
        _error = null;
        _success = null;
        _form = new WarehouseUpsertCommand { BranchId = _branches.FirstOrDefault()?.Id ?? 0, IsActive = true };
        _showForm = true;
        _isDirty = false;
    }

    private async Task Edit(WarehouseListItemDto item)
    {
        try
        {
            _error = null;
            _success = null;
            var detail = (await Api.GetAsync<AppResult<WarehouseDetailDto>>($"api/commerce/warehouses/{item.Id}"))?.Data;
            if (detail is null) return;
            _form = new WarehouseUpsertCommand { Id = detail.Id, BranchId = detail.BranchId, Name = detail.Name, IsMain = detail.IsMain, IsActive = detail.IsActive };
            _showForm = true;
            _isDirty = false;
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Save()
    {
        _error = ValidateEditor();
        if (!string.IsNullOrWhiteSpace(_error))
            return;

        _saving = true;
        try
        {
            if (_form.Id == 0) await Api.PostAsync("api/commerce/warehouses", new { _form.BranchId, _form.Name, _form.IsMain, _form.IsActive });
            else await Api.PutAsync($"api/commerce/warehouses/{_form.Id}", new { _form.Id, _form.BranchId, _form.Name, _form.IsMain, _form.IsActive });
            _showForm = false;
            _isDirty = false;
            _success = Ui.SaveMessage("Depósito", _form.Id == 0);
            await Load();
            Telemetry.Track("warehouses", "save", "success", _form.Id == 0 ? "create" : "update");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("warehouses", "save", "error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(WarehouseListItemDto item)
    {
        try
        {
            _error = null;
            _success = null;
            await Api.PostAsync($"api/commerce/warehouses/{item.Id}/status", new { isActive = !item.IsActive });
            _success = Ui.ToggleMessage("Depósito", item.IsActive);
            await Load();
            Telemetry.Track("warehouses", "toggle", "success", $"id={item.Id}");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("warehouses", "toggle", "error", ex.Message);
        }
    }

    private void Cancel()
    {
        _showForm = false;
        _isDirty = false;
        _error = null;
        _success = null;
    }
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }

    private string? ValidateEditor()
    {
        if (_form.BranchId <= 0)
            return "Seleccioná una sucursal para el depósito.";
        if (string.IsNullOrWhiteSpace(_form.Name))
            return "El nombre del depósito es obligatorio.";
        if (_form.Name.Length > 120)
            return "El nombre del depósito no puede superar los 120 caracteres.";
        return null;
    }

    private void MarkDirty() => _isDirty = true;

    private async Task ConfirmInternalNavigation(LocationChangingContext context)
    {
        if (!_showForm)
            return;

        var leave = await Guard.ConfirmDiscardAsync(JS, _isDirty, _saving, "Tenés cambios sin guardar. ¿Querés salir igual?");
        if (!leave)
            context.PreventNavigation();
    }
}
