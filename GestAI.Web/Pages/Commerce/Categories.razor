@page "/categories"
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@using System.Text.Json
@inject ApiClient Api
@inject GestAI.Web.Service.CommerceFormValidator FormValidator
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject IJSRuntime JS

<PageTitle>Categorías</PageTitle>

<ListPageHeader Title="Categorías"
                Subtitle="Ordená el catálogo con una jerarquía clara de categorías y subcategorías."
                ChipText="@($"{_result?.TotalCount ?? 0} categorías")"
                ChipIconClass="bi bi-diagram-3">
    <Actions>
        <button class="btn btn-primary" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nueva categoría</button>
    </Actions>
</ListPageHeader>

<FormFeedback Error="@_loadError" />

<ListPageFilters>
    <div class="row g-2 align-items-end">
        <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Nombre" /></div>
        <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activas</option><option value="false">Inactivas</option></select></div>
        <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-primary w-100" @onclick="Search">Buscar</button></div>
        <div class="col-12 col-md-6 col-lg-2 text-md-end ui-table-meta">Estructura del catálogo</div>
    </div>
</ListPageFilters>

<div class="ui-split-layout">
    <div>
        @if (!_loaded)
        {
            <div class="card"><div class="card-body">Cargando categorías...</div></div>
        }
        else if (_result?.Items.Count == 0)
        {
            <EmptyState Title="No hay categorías"
                        Description="Creá categorías para organizar mejor productos y variantes."
                        Icon="bi-diagram-3">
                <button class="btn btn-primary" @onclick="NewItem">Crear categoría</button>
            </EmptyState>
        }
        else
        {
            <div class="card ui-data-card @(_showForm ? "d-none" : string.Empty)">
                <div class="card-body">
                    <div class="ui-card-header">
                        <div>
                            <div class="ui-card-eyebrow">Catálogo y jerarquía</div>
                            <h5 class="ui-card-title">Listado de categorías</h5>
                            <div class="ui-card-subtitle">Vista tabular para edición rápida de la jerarquía.</div>
                        </div>
                    </div>
                    <UnifiedGrid ActionsDropdown="true">
                        <thead><tr><th>Nombre</th><th>Padre</th><th>Estado</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var item in _result!.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@(item.ParentCategoryName ?? "Raíz")</td>
                                <td><StatusBadge IsActive="@item.IsActive" /></td>
                                <td class="text-end">
                                    <div class="dropdown dropstart table-actions">
                                        <button class="ui-kebab-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Acciones">
                                            <i class="bi bi-three-dots-vertical"></i>
                                            <span class="visually-hidden">Acciones</span>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end ui-actions-menu">
                                            <li><button class="dropdown-item" type="button" @onclick="() => Edit(item)"><i class="bi bi-pencil-square me-2"></i>Editar</button></li>
                                            <li><button class="dropdown-item" type="button" @onclick="() => Toggle(item)"><i class="@($"bi {(item.IsActive ? "bi-toggle-off" : "bi-toggle-on")} me-2")"></i>@(item.IsActive ? "Desactivar" : "Activar")</button></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </UnifiedGrid>
                    <ListPaginationBar Page="@_page" TotalPages="@TotalPages" OnPrevious="PrevPage" OnNext="NextPage" />
                </div>
            </div>
        }
    </div>
    <div class="ui-section-grid">
        <div class="card">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Validación visual</div>
                        <h5 class="ui-card-title">Jerarquía</h5>
                        <div class="ui-card-subtitle">Vista simplificada de árbol para validar la estructura.</div>
                    </div>
                </div>
                @if (_tree.Count == 0)
                {
                    <p class="text-muted mb-0">Sin categorías.</p>
                }
                else
                {
                    <ul class="ui-tree-list">
                        @foreach (var line in FlattenTree(_tree, 0))
                        {
                            <li>@line</li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="card ui-form-card @(_showForm ? "w-100 ui-editor-open" : "ui-editor-hidden")">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Editor</div>
                        <h5 class="ui-card-title">@(_showForm ? (_form.Id == 0 ? "Nueva categoría" : "Editar categoría") : "Detalle y edición")</h5>
                        <div class="ui-card-subtitle">Definí la categoría y su relación jerárquica.</div>
                    </div>
                </div>

                @if (!_showForm)
                {
                    <EmptyState Title="Seleccioná una acción"
                                Description="Podés crear una categoría nueva o editar una existente."
                                Icon="bi-pencil-square">
                        <button class="btn btn-primary" @onclick="NewItem">Nueva categoría</button>
                    </EmptyState>
                }
                else
                {
                    <FormFeedback Error="@_error" Success="@_success" />
                    <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@(IsDirty)" />
                    <div class="row g-3">
                        <div class="col-12"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" /></div>
                        <div class="col-12"><label class="form-label">Padre</label><select class="form-select" @bind="_form.ParentCategoryId"><option value="">Sin padre</option>@foreach (var item in _allCategories.Where(x => x.Id != _form.Id)){<option value="@item.Id">@item.Name</option>}</select></div>
                        <div class="col-md-6"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" /><span>@(_form.IsActive ? "Categoría activa" : "Categoría inactiva")</span></div></div>
                    </div>
                    <div class="ui-action-bar">
                        <div class="ui-inline-actions">
                            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                            <button class="btn btn-outline-secondary" @onclick="Cancel" disabled="@_saving">Cancelar</button>
                        </div>
                        <span class="ui-table-meta">@((IsDirty) ? "Cambios sin guardar" : "Sin cambios pendientes")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private PagedResult<CategoryListItemDto>? _result;
    private List<CategoryTreeItemDto> _tree = new();
    private List<CategoryListItemDto> _allCategories = new();
    private string _search = string.Empty;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _showForm;
    private bool _saving;
    private int _page = 1;
    private const int PageSize = 10;
    private const int ParentOptionsPageSize = 50;
    private CategoryUpsertCommand _form = new();
    private string? _error;
    private string? _success;
    private string? _loadError;
    private string _formSnapshot = string.Empty;

    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Search() { _page = 1; await Load(); }

    private async Task Load()
    {
        _loaded = false;
        _loadError = null;
        try
        {
            var active = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
            _result = (await Api.GetAsync<AppResult<PagedResult<CategoryListItemDto>>>($"api/commerce/categories?search={Uri.EscapeDataString(_search ?? string.Empty)}{active}&page={_page}&pageSize={PageSize}"))?.Data;
            _allCategories = (await Api.GetAsync<AppResult<PagedResult<CategoryListItemDto>>>($"api/commerce/categories?pageSize={ParentOptionsPageSize}"))?.Data?.Items.ToList() ?? new();
            _tree = (await Api.GetAsync<AppResult<List<CategoryTreeItemDto>>>("api/commerce/categories/tree"))?.Data ?? new();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _loadError = ex.Message;
            _result = null;
            _allCategories = new();
            _tree = new();
        }
        _loaded = true;
    }

    private IEnumerable<string> FlattenTree(IEnumerable<CategoryTreeItemDto> nodes, int level)
    {
        foreach (var node in nodes)
        {
            yield return $"{new string('—', level)} {node.Name}".Trim();
            foreach (var child in FlattenTree(node.Children, level + 1))
            {
                yield return child;
            }
        }
    }

    private void NewItem()
    {
        _form = new CategoryUpsertCommand { IsActive = true };
        _showForm = true;
        MarkClean();
    }

    private async Task Edit(CategoryListItemDto item)
    {
        var detail = (await Api.GetAsync<AppResult<CategoryDetailDto>>($"api/commerce/categories/{item.Id}"))?.Data;
        if (detail is null) return;
        _form = new CategoryUpsertCommand { Id = detail.Id, Name = detail.Name, ParentCategoryId = detail.ParentCategoryId, IsActive = detail.IsActive };
        _showForm = true;
        MarkClean();
    }

    private async Task Save()
    {
        _error = null;
        _success = null;
        var validation = ValidateEditor();
        if (validation.Count > 0)
        {
            _error = string.Join(" ", validation);
            Telemetry.Track("categories", "validate", "error", string.Join(" | ", validation));
            return;
        }
        _saving = true;
        try
        {
            if (_form.Id == 0) await Api.PostAsync("api/commerce/categories", new { _form.Name, _form.ParentCategoryId, _form.IsActive });
            else await Api.PutAsync($"api/commerce/categories/{_form.Id}", new { _form.Id, _form.Name, _form.ParentCategoryId, _form.IsActive });
            _showForm = false;
            _success = "Categoría guardada correctamente.";
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(CategoryListItemDto item)
    {
        _error = null;
        _success = null;
        try
        {
            await Api.PostAsync($"api/commerce/categories/{item.Id}/status", new { isActive = !item.IsActive });
            _success = item.IsActive ? "Categoría desactivada." : "Categoría activada.";
            await Load();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Cancel()
    {
        if (!await ConfirmDiscardIfDirtyAsync())
            return;
        _showForm = false;
    }
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }

    private List<string> ValidateEditor()
        => FormValidator.ValidateCategory(_form.Name, _form.ParentCategoryId, _form.Id);

    private string BuildSnapshot()
        => JsonSerializer.Serialize(new
        {
            _form.Id,
            _form.Name,
            _form.ParentCategoryId,
            _form.IsActive
        });

    private bool IsDirty => _showForm && _formSnapshot != BuildSnapshot();

    private void MarkClean() => _formSnapshot = BuildSnapshot();

    private async Task<bool> ConfirmDiscardIfDirtyAsync()
        => await Guard.ConfirmDiscardAsync(JS, IsDirty, _saving);
}
