@page "/sales/{Id:int}"
@using GestAI.Web.Dtos
@inject ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Detalle de venta</PageTitle>

@if (_detail is null)
{
    <div class="card"><div class="card-body">Cargando venta...</div></div>
}
else
{
    <section class="page-hero">
        <div>
            <div class="page-hero-title">@_detail.Number</div>
            <div class="page-hero-subtitle">Vista de detalle de la venta con trazabilidad de origen, líneas y resumen económico.</div>
        </div>
        <div class="page-hero-meta">
            <StatusBadge Text="@SaleStatusLabel(_detail.Status)" CssClass="@SaleStatusClass(_detail.Status)" />
            <button class="btn btn-outline-secondary" @onclick="GoBack">Volver</button>
            <button class="btn btn-outline-primary" @onclick="DownloadPdf">Descargar PDF</button>
            @if (_detail.SourceQuoteId.HasValue)
            {
                <a class="btn btn-outline-primary" href="/quotes/@_detail.SourceQuoteId.Value">Ver presupuesto origen</a>
            }
        </div>
    </section>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card ui-data-card"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Cabecera</div><h5 class="ui-card-title">Documento de venta</h5><div class="ui-card-subtitle">Cliente, fechas, estado y origen comercial.</div></div></div>
                <div class="row g-3">
                    <div class="col-md-6"><div class="ui-table-stack"><span class="fw-semibold">Cliente</span><span class="ui-table-meta">@_detail.CustomerName</span></div></div>
                    <div class="col-md-3"><div class="ui-table-stack"><span class="fw-semibold">Fecha</span><span class="ui-table-meta">@_detail.IssuedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</span></div></div>
                    <div class="col-md-3"><div class="ui-table-stack"><span class="fw-semibold">Origen</span><span class="ui-table-meta">@(_detail.SourceQuoteId.HasValue ? _detail.SourceQuoteNumber : "Venta manual")</span></div></div>
                    <div class="col-12"><div class="ui-table-stack"><span class="fw-semibold">Observaciones</span><span class="ui-table-meta">@(!string.IsNullOrWhiteSpace(_detail.Observations) ? _detail.Observations : "Sin observaciones")</span></div></div>
                </div>
            </div></div>
            <div class="card ui-data-card mt-3"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Detalle</div><h5 class="ui-card-title">Ítems vendidos</h5><div class="ui-card-subtitle">Snapshot exacto usado para esta venta.</div></div></div>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead><tr><th>Descripción</th><th>Código</th><th>Cantidad</th><th>Precio</th><th>Subtotal</th></tr></thead>
                        <tbody>
                        @foreach (var line in _detail.Items.OrderBy(x => x.SortOrder))
                        {
                            <tr><td>@line.Description</td><td>@line.InternalCode</td><td>@line.Quantity</td><td>@line.UnitPrice.ToString("C")</td><td class="fw-semibold">@line.LineSubtotal.ToString("C")</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div></div>
        </div>
        <div class="col-lg-4">
            <div class="card"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Totales</div><h5 class="ui-card-title">Resumen económico</h5></div></div>
                <div class="ui-list-stack">
                    <div class="ui-check-card"><i class="bi bi-calculator text-primary"></i><div><strong>Subtotal</strong><div class="ui-table-meta">@_detail.Subtotal.ToString("C")</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-cash-stack text-primary"></i><div><strong>Total</strong><div class="ui-table-meta">@_detail.Total.ToString("C")</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-card-list text-primary"></i><div><strong>Líneas</strong><div class="ui-table-meta">@(_detail.Items.Count == 1 ? "1 ítem" : $"{_detail.Items.Count} ítems")</div></div></div>
                </div>
            </div></div>
            <div class="card mt-3"><div class="card-body">
                <div class="ui-card-header"><div><div class="ui-card-eyebrow">Auditoría básica</div><h5 class="ui-card-title">Seguimiento</h5></div></div>
                <div class="ui-table-stack mb-3"><span class="fw-semibold">Creado</span><span class="ui-table-meta">@_detail.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") | @_detail.CreatedByUserId</span></div>
                <div class="ui-table-stack"><span class="fw-semibold">Última modificación</span><span class="ui-table-meta">@(_detail.ModifiedAtUtc.HasValue ? $"{_detail.ModifiedAtUtc.Value.ToLocalTime():dd/MM/yyyy HH:mm} | {_detail.ModifiedByUserId}" : "Sin cambios posteriores")</span></div>
            </div></div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private SaleDetailDto? _detail;

    protected override async Task OnParametersSetAsync()
        => _detail = (await Api.GetAsync<AppResult<SaleDetailDto>>($"api/commerce/sales/{Id}"))?.Data;

    private async Task DownloadPdf()
    {
        if (_detail is null)
            return;

        var bytes = await Api.GetBytesAsync($"api/commerce/sales/{Id}/pdf");
        await JS.InvokeVoidAsync("gestAiDownloadFile", $"{_detail.Number}.pdf", "application/pdf", Convert.ToBase64String(bytes));
    }

    private void GoBack() => Navigation.NavigateTo("/sales");

    private static string SaleStatusLabel(SaleStatus status) => status switch
    {
        SaleStatus.Draft => "Borrador",
        SaleStatus.Confirmed => "Confirmada",
        SaleStatus.Completed => "Completada",
        SaleStatus.Cancelled => "Cancelada",
        _ => status.ToString()
    };

    private static string SaleStatusClass(SaleStatus status) => status switch
    {
        SaleStatus.Completed => "ui-badge ui-badge-success",
        SaleStatus.Confirmed => "ui-badge ui-badge-primary",
        SaleStatus.Cancelled => "ui-badge ui-badge-danger",
        _ => "ui-badge ui-badge-neutral"
    };
}
