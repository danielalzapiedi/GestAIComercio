@page "/customers"
@page "/customers/{Mode}"
@page "/customers/edit/{EditId:int}"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@inject ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject CommerceMasterUiService Ui

<PageTitle>Clientes</PageTitle>

<section class="page-hero">
    <div>
        <div class="page-hero-title">Clientes</div>
        <div class="page-hero-subtitle">Centralizá datos comerciales y mantené un padrón claro de clientes.</div>
    </div>
    <div class="page-hero-meta">
        @if (IsEditorRoute)
        {
            <button class="btn btn-outline-secondary" @onclick="BackToList"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <span class="page-hero-chip"><i class="bi bi-person-vcard"></i> @(_result?.TotalCount ?? 0) clientes</span>
            <button class="btn btn-primary" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nuevo cliente</button>
        }
    </div>
</section>

@if (!_loaded)
{
    <div class="card"><div class="card-body">Cargando clientes...</div></div>
}
else if (IsEditorRoute)
{
    <NavigationLock ConfirmExternalNavigation="@_isDirty" OnBeforeInternalNavigation="@ConfirmInternalNavigation" />
    <div class="card ui-form-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Editor</div>
                    <h5 class="ui-card-title">@(_form.Id == 0 ? "Nuevo cliente" : "Editar cliente")</h5>
                    <div class="ui-card-subtitle">Completá datos fiscales, de contacto y clasificación.</div>
                </div>
            </div>
            <FormFeedback Error="@_error" Success="@_success" />
            <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@_isDirty" />

            <div class="row g-3">
                <div class="col-md-8"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" @bind:after="MarkDirty" /></div>
                <div class="col-md-4"><label class="form-label">CUIT/DNI</label><input class="form-control" @bind="_form.DocumentNumber" @bind:after="MarkDirty" /></div>
                <div class="col-md-6"><label class="form-label">Teléfono</label><input class="form-control" @bind="_form.Phone" @bind:after="MarkDirty" /></div>
                <div class="col-md-6"><label class="form-label">Dirección</label><input class="form-control" @bind="_form.Address" @bind:after="MarkDirty" /></div>
                <div class="col-md-6"><label class="form-label">Localidad</label><input class="form-control" @bind="_form.City" @bind:after="MarkDirty" /></div>
                <div class="col-md-6"><label class="form-label">Tipo</label><select class="form-select" @bind="_form.CustomerType" @bind:after="MarkDirty">@foreach (var type in Enum.GetValues<CustomerType>()){<option value="@type">@type</option>}</select></div>
                <div class="col-md-6"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" @bind:after="MarkDirty" /><span>@(_form.IsActive ? "Cliente activo" : "Cliente inactivo")</span></div></div>
            </div>
            <div class="ui-action-bar">
                <div class="ui-inline-actions">
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                    <button class="btn btn-outline-secondary" @onclick="BackToList">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
}
else if (HasLoadError)
{
    <div class="card ui-data-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Error de carga</div>
                    <h5 class="ui-card-title">No pudimos obtener los clientes</h5>
                    <div class="ui-card-subtitle">Revisá la conexión o intentá nuevamente en unos segundos.</div>
                </div>
            </div>
            <FormFeedback Error="@_error" />
            <div class="ui-action-bar">
                <button class="btn btn-outline-primary" @onclick="Load"><i class="bi bi-arrow-clockwise me-2"></i>Reintentar</button>
            </div>
        </div>
    </div>
}
else if (_result?.Items.Count == 0)
{
    <FormFeedback Error="@_error" Success="@_success" />
    <EmptyState Title="No hay clientes"
                Description="Creá el primer cliente para empezar a registrar relaciones comerciales."
                Icon="bi-person-vcard">
        <button class="btn btn-primary" @onclick="NewItem">Crear cliente</button>
    </EmptyState>
}
else
{
    <FormFeedback Error="@_error" Success="@_success" />
    <div class="card ui-filter-card"><div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-lg-5 col-md-12"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" @onkeydown="HandleSearchKeyDown" placeholder="Nombre, doc, teléfono" /></div>
            <div class="col-lg-3 col-md-6"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activos</option><option value="false">Inactivos</option></select></div>
            <div class="col-lg-2 col-md-3"><button class="btn btn-outline-primary w-100 text-nowrap" @onclick="Search">Buscar</button></div>
            <div class="col-lg-2 col-md-3"><button class="btn btn-outline-secondary w-100 text-nowrap" @onclick="ClearFilters">Limpiar</button></div>
        </div>
    </div></div>

    <div class="card ui-data-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Base comercial</div>
                    <h5 class="ui-card-title">Listado de clientes</h5>
                    <div class="ui-card-subtitle">Información principal y segmento comercial.</div>
                </div>
            </div>
            <div class="table-responsive">
            <table class="table ui-modern-grid">
                <thead><tr><th>Nombre</th><th>Documento</th><th>Teléfono</th><th>Localidad</th><th>Tipo</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in _result!.Items)
                {
                    <tr>
                        <td><div class="ui-table-stack"><span class="fw-semibold ui-cell-truncate" title="@item.Name">@item.Name</span></div></td>
                        <td><div class="ui-table-stack"><span>@(item.DocumentNumber ?? "-")</span></div></td>
                        <td><div class="ui-table-stack"><span class="ui-cell-truncate" title="@(item.Phone ?? "-")">@(item.Phone ?? "-")</span></div></td>
                        <td><div class="ui-table-stack"><span class="ui-cell-truncate" title="@(item.City ?? "-")">@(item.City ?? "-")</span></div></td>
                        <td><div class="ui-table-stack"><StatusBadge Text="@item.CustomerType.ToString()" /></div></td>
                        <td><div class="ui-table-stack"><StatusBadge IsActive="@item.IsActive" /></div></td>
                        <td class="text-end">
                            <div class="dropdown table-actions">
                                <button class="ui-kebab-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Acciones">
                                    <i class="bi bi-three-dots-vertical"></i>
                                    <span class="visually-hidden">Acciones</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end ui-actions-menu">
                                    <li><button class="dropdown-item" type="button" @onclick="() => Edit(item)"><i class="bi bi-pencil-square me-2"></i>Editar</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick="() => Toggle(item)"><i class="@($"bi {(item.IsActive ? "bi-toggle-off" : "bi-toggle-on")} me-2")"></i>@(item.IsActive ? "Desactivar" : "Activar")</button></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            </div>
            <div class="ui-action-bar">
                <span class="text-muted">Página @_page de @TotalPages</span>
                <div class="btn-group">
                    <button class="btn btn-outline-secondary" disabled="@(_page <= 1)" @onclick="PrevPage">Anterior</button>
                    <button class="btn btn-outline-secondary" disabled="@(_page >= TotalPages)" @onclick="NextPage">Siguiente</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Mode { get; set; }
    [Parameter] public int? EditId { get; set; }

    private PagedResult<CustomerListItemDto>? _result;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _saving;
    private bool _isDirty;
    private int _page = 1;
    private const int PageSize = 10;
    private CustomerUpsertCommand _form = new();
    private string? _error;
    private string? _success;

    private bool IsNewRoute => string.Equals(Mode, "new", StringComparison.OrdinalIgnoreCase);
    private bool IsEditRoute => EditId.HasValue;
    private bool IsEditorRoute => IsNewRoute || IsEditRoute;
    private bool HasLoadError => !IsEditorRoute && !string.IsNullOrWhiteSpace(_error) && (_result?.Items.Count ?? 0) == 0;
    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;

        if (IsEditorRoute)
            await LoadEditor();
        else
            await Load();

        _loaded = true;
    }

    private async Task Search()
    {
        _page = 1;
        await Load();
        Telemetry.Track("customers", "search", "success");
    }

    private async Task ClearFilters()
    {
        _search = string.Empty;
        _status = string.Empty;
        _page = 1;
        await Load();
        Telemetry.Track("customers", "clear-filters", "success");
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await Search();
    }

    private async Task Load()
    {
        try
        {
            _error = null;
            var active = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
            _result = (await Api.GetAsync<AppResult<PagedResult<CustomerListItemDto>>>($"api/commerce/customers?search={Uri.EscapeDataString(_search ?? string.Empty)}{active}&page={_page}&pageSize={PageSize}"))?.Data;
            Telemetry.Track("customers", "load", "success");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("customers", "load", "error", ex.Message);
            _result = new PagedResult<CustomerListItemDto>(new List<CustomerListItemDto>(), 0, _page, PageSize);
        }
    }

    private async Task LoadEditor()
    {
        if (IsNewRoute)
        {
            _error = null;
            _success = null;
            _form = new CustomerUpsertCommand { IsActive = true, CustomerType = CustomerType.Mixed };
            _isDirty = false;
            return;
        }

        if (!EditId.HasValue)
        {
            BackToList();
            return;
        }

        try
        {
            _error = null;
            _success = null;
            var detail = (await Api.GetAsync<AppResult<CustomerDetailDto>>($"api/commerce/customers/{EditId.Value}"))?.Data;
            if (detail is null)
            {
                BackToList();
                return;
            }

            _form = new CustomerUpsertCommand { Id = detail.Id, Name = detail.Name, DocumentNumber = detail.DocumentNumber, Phone = detail.Phone, Address = detail.Address, City = detail.City, CustomerType = detail.CustomerType, IsActive = detail.IsActive };
            _isDirty = false;
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private void NewItem()
    {
        _error = null;
        _success = null;
        _form = new CustomerUpsertCommand { IsActive = true, CustomerType = CustomerType.Mixed };
        _isDirty = false;
        Nav.NavigateTo("/customers/new");
    }

    private void Edit(CustomerListItemDto item) => Nav.NavigateTo($"/customers/edit/{item.Id}");

    private async Task Save()
    {
        _error = ValidateEditor();
        if (!string.IsNullOrWhiteSpace(_error))
            return;

        _saving = true;
        try
        {
            if (_form.Id == 0) await Api.PostAsync("api/commerce/customers", new { _form.Name, _form.DocumentNumber, _form.Phone, _form.Address, _form.City, _form.CustomerType, _form.IsActive });
            else await Api.PutAsync($"api/commerce/customers/{_form.Id}", new { _form.Id, _form.Name, _form.DocumentNumber, _form.Phone, _form.Address, _form.City, _form.CustomerType, _form.IsActive });

            _isDirty = false;
            _success = Ui.SaveMessage("Cliente", _form.Id == 0);
            Telemetry.Track("customers", "save", "success", _form.Id == 0 ? "create" : "update");
            BackToList();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("customers", "save", "error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(CustomerListItemDto item)
    {
        try
        {
            _error = null;
            _success = null;
            await Api.PostAsync($"api/commerce/customers/{item.Id}/status", new { isActive = !item.IsActive });
            _success = Ui.ToggleMessage("Cliente", item.IsActive);
            await Load();
            Telemetry.Track("customers", "toggle", "success", $"id={item.Id}");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("customers", "toggle", "error", ex.Message);
        }
    }

    private void BackToList()
    {
        _isDirty = false;
        Nav.NavigateTo("/customers");
    }
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }

    private string? ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
            return "El nombre del cliente es obligatorio.";
        if (_form.Name.Length > 160)
            return "El nombre no puede superar los 160 caracteres.";
        if (!string.IsNullOrWhiteSpace(_form.DocumentNumber) && _form.DocumentNumber.Length > 30)
            return "El CUIT/DNI no puede superar los 30 caracteres.";
        if (!string.IsNullOrWhiteSpace(_form.Phone) && _form.Phone.Length > 40)
            return "El teléfono no puede superar los 40 caracteres.";
        return null;
    }

    private void MarkDirty() => _isDirty = true;

    private async Task ConfirmInternalNavigation(LocationChangingContext context)
    {
        var leave = await Guard.ConfirmDiscardAsync(JS, _isDirty, _saving, "Tenés cambios sin guardar. ¿Querés salir igual?");
        if (!leave)
            context.PreventNavigation();
    }
}
