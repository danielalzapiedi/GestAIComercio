@page "/quotes"
@page "/quotes/{Mode}"
@page "/quotes/edit/{EditId:int}"
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@using Microsoft.AspNetCore.Components.Web
@using System.Text.Json
@inject ApiClient Api
@inject GestAI.Web.Service.CommerceFormValidator FormValidator
@inject NavigationManager Navigation
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject IJSRuntime JS

<PageTitle>Presupuestos</PageTitle>

<ListPageHeader Title="Presupuestos"
                Subtitle="Armá propuestas comerciales reales, con cliente, vigencia, estados claros y conversión posterior a venta."
                ChipText="@($"{_result?.TotalCount ?? 0} presupuestos")"
                ChipIconClass="bi bi-file-earmark-text">
    <Actions>
        @if (_showForm)
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="BackToList"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <button class="btn btn-primary" type="button" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nuevo presupuesto</button>
        }
    </Actions>
</ListPageHeader>

@if (!_showForm)
{
    <div class="row g-3 ui-summary-grid mb-1">
        <div class="col-sm-6 col-xl-4"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Convertibles</div><div class="ui-stat-value">@ConvertibleCount</div><div class="ui-stat-foot">Presupuestos válidos y no convertidos en la página.</div></div></div></div>
        <div class="col-sm-6 col-xl-4"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Total visible</div><div class="ui-stat-value">@VisibleTotal.ToString("C")</div><div class="ui-stat-foot">Total comercial acumulado de la página actual.</div></div></div></div>
        <div class="col-sm-6 col-xl-4"><div class="card ui-stat-card"><div class="card-body"><div class="ui-stat-label">Cliente filtro</div><div class="ui-stat-value">@SelectedCustomerLabel</div><div class="ui-stat-foot">@StatusFilterLabel</div></div></div></div>
    </div>
}

@if (!_showForm)
{
    <ListPageFilters>
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" @onkeydown="HandleSearchKeyDown" placeholder="Número, cliente" /></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Cliente</label><select class="form-select" @bind="_customerId"><option value="0">Todos</option>@foreach (var customer in _seed.Customers){<option value="@customer.Id">@customer.Name</option>}</select></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option>@foreach (var status in Enum.GetValues<QuoteStatus>()){<option value="@status">@QuoteStatusLabel(status)</option>}</select></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Conversión</label><select class="form-select" @bind="_onlyConvertible"><option value="">Todos</option><option value="true">Solo convertibles</option></select></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-primary w-100 text-nowrap" type="button" @onclick="Search">Buscar</button></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-secondary w-100 text-nowrap" type="button" @onclick="ClearFilters">Limpiar</button></div>
        </div>
    </ListPageFilters>
}
<div class="ui-split-layout ui-split-layout-focus-editor">
    <div class="@(_showForm ? "d-none" : string.Empty)">
        @if (!_loaded)
        {
            <div class="card"><div class="card-body">Cargando presupuestos...</div></div>
        }
        else if (HasLoadError)
        {
            <div class="card ui-data-card">
                <div class="card-body">
                    <div class="ui-card-header">
                        <div>
                            <div class="ui-card-eyebrow">Error de carga</div>
                            <h5 class="ui-card-title">No pudimos obtener los presupuestos</h5>
                            <div class="ui-card-subtitle">Revisá la conexión o intentá nuevamente para continuar.</div>
                        </div>
                    </div>
                    <FormFeedback Error="@_loadError" />
                    <div class="ui-action-bar">
                        <button class="btn btn-outline-primary" type="button" @onclick="Load"><i class="bi bi-arrow-clockwise me-2"></i>Reintentar</button>
                    </div>
                </div>
            </div>
        }
        else if (_result?.Items.Count == 0 && !_showForm)
        {
            <EmptyState Title="No hay presupuestos"
                        Description="Creá el primer presupuesto comercial para iniciar el circuito de cotización y cierre."
                        Icon="bi-file-earmark-text">
                <button class="btn btn-primary" type="button" @onclick="NewItem">Crear presupuesto</button>
            </EmptyState>
        }
        else
        {
            @if (_result?.Items.Count == 0)
            {
                <EmptyState Title="Todavía no hay presupuestos cargados"
                            Description="Podés crear el primer presupuesto desde la pantalla de edición."
                            Icon="bi-file-earmark-text">
                    <button class="btn btn-primary" type="button" @onclick="NewItem">Nuevo presupuesto</button>
                </EmptyState>
            }
            else
            {
                <div class="card ui-data-card ui-data-card-actions @(_showForm ? "d-none" : string.Empty)"><div class="card-body">
                    <div class="ui-card-header">
                        <div>
                            <div class="ui-card-eyebrow">Documentos comerciales</div>
                            <h5 class="ui-card-title">Listado de presupuestos</h5>
                            <div class="ui-card-subtitle">Con seguimiento de estado, vigencia, cliente y pasaje a venta.</div>
                        </div>
                    </div>
                    <UnifiedGrid ActionsDropdown="true">
                            <thead><tr><th>Comprobante</th><th>Cliente</th><th>Fechas</th><th>Items</th><th>Total</th><th>Estado</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var item in _result!.Items)
                            {
                                <tr>
                                    <td><div class="ui-table-stack"><span class="fw-semibold ui-cell-truncate" title="@item.Number">@item.Number</span><span class="ui-table-meta">Presupuesto comercial</span></div></td>
                                    <td><div class="ui-table-stack"><span class="fw-semibold ui-cell-truncate" title="@item.CustomerName">@item.CustomerName</span><span class="ui-table-meta">Cliente asociado</span></div></td>
                                    <td><div class="ui-table-stack"><span class="fw-semibold">@item.IssuedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</span><span class="ui-table-meta">Vence @(item.ValidUntilUtc.HasValue ? item.ValidUntilUtc.Value.ToLocalTime().ToString("dd/MM/yyyy") : "sin fecha")</span></div></td>
                                    <td><StatusBadge Text="@(item.ItemsCount == 1 ? "1 ítem" : $"{item.ItemsCount} ítems")" CssClass="ui-badge ui-badge-neutral" /></td>
                                    <td><div class="ui-table-stack"><span class="fw-semibold ui-table-total">@item.Total.ToString("C")</span><span class="ui-table-meta">Subtotal @item.Subtotal.ToString("C")</span></div></td>
                                    <td><StatusBadge Text="@QuoteStatusLabel(item.Status)" CssClass="@($"{QuoteStatusClass(item.Status)} ui-badge-emphasis")" /></td>
                                    <td class="text-end">
                                        <div class="dropdown dropstart table-actions">
                                            <button class="ui-kebab-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Acciones">
                                                <i class="bi bi-three-dots-vertical"></i>
                                                <span class="visually-hidden">Acciones</span>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end ui-actions-menu">
                                                <li><button class="dropdown-item" type="button" @onclick="() => Edit(item.Id)"><i class="bi bi-pencil-square me-2"></i>Editar</button></li>
                                                <li><button class="dropdown-item" type="button" @onclick="() => OpenDetail(item.Id)"><i class="bi bi-eye me-2"></i>Detalle</button></li>
                                                @if (item.CanConvertToSale)
                                                {
                                                    <li><button class="dropdown-item" type="button" @onclick="() => Convert(item.Id)"><i class="bi bi-arrow-left-right me-2"></i>Convertir</button></li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </UnifiedGrid>
                    <ListPaginationBar Page="@_page" TotalPages="@TotalPages" OnPrevious="PrevPage" OnNext="NextPage" />
                </div></div>
            }
        }
    </div>

    <div class="ui-section-grid @(_showForm ? "w-100" : string.Empty)">
        <div class="card ui-form-card @(_showForm ? "w-100" : "d-none")" id="quotes-editor">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Carga guiada</div>
                        <h5 class="ui-card-title">@(_form.Id == 0 ? "Nuevo presupuesto" : $"Editar {_editingNumber}")</h5>
                        <div class="ui-card-subtitle">Armá el presupuesto desde un panel único y visible, sin perder de vista el total ni la vigencia.</div>
                    </div>
                </div>

                @if (!_showForm)
                {
                    <EmptyState Title="Seleccioná una acción"
                                Description="Usá Nuevo presupuesto para abrir el formulario listo para completar, o editá uno existente desde el listado."
                                Icon="bi-pencil-square">
                        <button class="btn btn-primary" type="button" @onclick="NewItem">Nuevo presupuesto</button>
                    </EmptyState>
                }
                else
                {
                    <FormFeedback Error="@_error" Success="@_success" />
                    <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@(IsDirty)" />
                    <div class="ui-form-section">
                        <div class="ui-form-section-title">Cabecera</div>
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label">Cliente</label><select class="form-select" @bind="_form.CustomerId"><option value="0">Seleccionar cliente</option>@foreach (var customer in _seed.Customers){<option value="@customer.Id">@customer.Name</option>}</select></div>
                            <div class="col-md-3"><label class="form-label">Fecha</label><input class="form-control" type="date" @bind-value="_issuedAtDate" /></div>
                            <div class="col-md-3"><label class="form-label">Vencimiento</label><input class="form-control" type="date" @bind-value="_validUntilDate" /></div>
                            <div class="col-md-6"><label class="form-label">Estado</label><select class="form-select" @bind="_form.Status">@foreach (var status in Enum.GetValues<QuoteStatus>()){<option value="@status">@QuoteStatusLabel(status)</option>}</select></div>
                            <div class="col-md-6"><label class="form-label">Observaciones</label><input class="form-control" @bind="_form.Observations" placeholder="Notas comerciales, alcance, condiciones" /></div>
                        </div>
                    </div>

                    <div class="ui-form-section">
                        <div class="ui-variant-head">
                            <div>
                                <div class="ui-form-section-title mb-1">Ítems</div>
                                <div class="ui-card-subtitle mt-0">Carga ágil con productos o variantes y edición mínima de cantidad/precio.</div>
                                <div class="ui-table-meta">@PricingPolicy.StandardSalePolicyDescription</div>
                            </div>
                            <button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddBlankLine">Agregar línea</button>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-12"><label class="form-label">Búsqueda rápida</label><input class="form-control" @bind="_quickSearch" placeholder="Buscar por nombre o código" /></div>
                            @if (QuickMatches.Count > 0)
                            {
                                <div class="col-12">
                                    <div class="list-group ui-search-list">
                                        @foreach (var sku in QuickMatches)
                                        {
                                            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick="() => AddSku(sku)">
                                                <span><strong>@sku.Label</strong><span class="ui-table-meta ms-2">@sku.InternalCode</span></span>
                                                <span>@sku.SalePrice.ToString("C")</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        @if (_form.Items.Count == 0)
                        {
                            <EmptyState Title="Sin líneas cargadas"
                                        Description="Agregá productos para calcular subtotal y total del presupuesto."
                                        Icon="bi-card-list">
                                <button class="btn btn-outline-primary" type="button" @onclick="AddBlankLine">Agregar línea</button>
                            </EmptyState>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead><tr><th>Descripción</th><th>Código</th><th>Cantidad</th><th>Precio</th><th>Subtotal</th><th></th></tr></thead>
                                    <tbody>
                                    @for (var i = 0; i < _form.Items.Count; i++)
                                    {
                                        var line = _form.Items[i];
                                        var rowIndex = i;
                                        <tr>
                                            <td><input class="form-control" @bind="line.Description" /></td>
                                            <td><input class="form-control" @bind="line.InternalCode" /></td>
                                            <td><input class="form-control" type="number" step="0.01" @bind="line.Quantity" /></td>
                                            <td><input class="form-control" type="number" step="0.01" @bind="line.UnitPrice" /></td>
                                            <td class="fw-semibold">@line.LineSubtotal.ToString("C")</td>
                                            <td><button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => RemoveLine(rowIndex)" title="Quitar línea" aria-label="Quitar línea"><i class="bi bi-trash"></i></button></td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <div class="ui-action-bar">
                        <div class="ui-inline-actions">
                            <button class="btn btn-primary" type="button" @onclick="Save" disabled="@_saving">Guardar</button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="Cancel" disabled="@_saving">Cancelar</button>
                        </div>
                        <div class="ui-table-stack text-end">
                            <span class="fw-semibold">Total @FormTotal.ToString("C")</span>
                            <span class="ui-table-meta">@(_form.Items.Count == 1 ? "1 ítem" : $"{_form.Items.Count} ítems")</span>
                            <span class="ui-table-meta">@((IsDirty) ? "Cambios sin guardar" : "Sin cambios pendientes")</span>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card @(_showForm ? "d-none" : string.Empty)">
            <div class="card-body">
                <div class="ui-card-header">
                    <div>
                        <div class="ui-card-eyebrow">Ayuda rápida</div>
                        <h5 class="ui-card-title">Cómo armar un presupuesto</h5>
                        <div class="ui-card-subtitle">La guía queda debajo para priorizar primero la tarea principal.</div>
                    </div>
                </div>
                <div class="ui-list-stack">
                    <div class="ui-check-card"><i class="bi bi-1-circle text-primary"></i><div><strong>Elegí cliente y fechas</strong><div class="ui-table-meta">La vigencia ayuda a decidir si todavía puede convertirse a venta.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-2-circle text-primary"></i><div><strong>Sumá los ítems</strong><div class="ui-table-meta">Podés usar búsqueda rápida o cargar una línea manual para empezar.</div></div></div>
                    <div class="ui-check-card"><i class="bi bi-3-circle text-primary"></i><div><strong>Convertí cuando esté listo</strong><div class="ui-table-meta">El presupuesto mantiene su trazabilidad y luego puede pasar a venta.</div></div></div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Mode { get; set; }
    [Parameter] public int? EditId { get; set; }

    private PagedResult<QuoteListItemDto>? _result;
    private CommercialDocumentSeedDataDto _seed = new(Array.Empty<LookupDto>(), Array.Empty<CommercialSkuLookupDto>(), Array.Empty<CommercialSkuLookupDto>());
    private readonly List<CommercialSkuLookupDto> _skuIndex = new();
    private QuoteUpsertCommand _form = new();
    private bool _loaded;
    private bool _showForm;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private string _onlyConvertible = string.Empty;
    private string _quickSearch = string.Empty;
    private int _customerId;
    private int _page = 1;
    private const int PageSize = 10;
    private string _editingNumber = string.Empty;
    private DateTime _issuedAtDate = DateTime.UtcNow.Date;
    private DateTime? _validUntilDate;
    private bool _saving;
    private string? _error;
    private string? _success;
    private string? _loadError;
    private string _formSnapshot = string.Empty;
    private bool _seedLoaded;

    private bool IsNewRoute => string.Equals(Mode, "new", StringComparison.OrdinalIgnoreCase);
    private bool IsEditRoute => EditId.HasValue;
    private bool IsEditorRoute => IsNewRoute || IsEditRoute;
    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);
    private bool HasLoadError => !IsEditorRoute && !string.IsNullOrWhiteSpace(_loadError);
    private int ConvertibleCount => _result?.Items.Count(x => x.CanConvertToSale) ?? 0;
    private decimal VisibleTotal => _result?.Items.Sum(x => x.Total) ?? 0m;
    private string SelectedCustomerLabel => _customerId == 0 ? "Todos" : _seed.Customers.FirstOrDefault(x => x.Id == _customerId)?.Name ?? "Cliente";
    private string StatusFilterLabel => string.IsNullOrWhiteSpace(_status) ? "Sin filtro de estado" : QuoteStatusLabel(Enum.Parse<QuoteStatus>(_status));
    private decimal FormTotal => _form.Items.Sum(x => x.LineSubtotal);
    private List<CommercialSkuLookupDto> QuickMatches => string.IsNullOrWhiteSpace(_quickSearch)
        ? new()
        : _skuIndex.Where(x => x.IsActive && (x.Label.Contains(_quickSearch, StringComparison.OrdinalIgnoreCase) || x.InternalCode.Contains(_quickSearch, StringComparison.OrdinalIgnoreCase))).Take(6).ToList();

    protected override async Task OnParametersSetAsync()
    {
        if (!_seedLoaded)
        {
            await LoadSeed();
            _seedLoaded = true;
        }

        _showForm = IsEditorRoute;
        if (IsNewRoute)
        {
            PrepareNewForm();
            return;
        }

        if (IsEditRoute && EditId.HasValue)
        {
            await LoadEditor(EditId.Value);
            return;
        }

        await Load();
    }

    private void BackToList()
    {
        _showForm = false;
        _error = null;
        Navigation.NavigateTo("/quotes");
    }

    private async Task LoadSeed()
    {
        _seed = (await Api.GetAsync<AppResult<CommercialDocumentSeedDataDto>>("api/commerce/commercial/seed"))?.Data
            ?? new CommercialDocumentSeedDataDto(Array.Empty<LookupDto>(), Array.Empty<CommercialSkuLookupDto>(), Array.Empty<CommercialSkuLookupDto>());
        _skuIndex.Clear();
        _skuIndex.AddRange(_seed.Products);
        _skuIndex.AddRange(_seed.Variants);
    }

    private async Task Load()
    {
        _loaded = false;
        _loadError = null;
        try
        {
            var status = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&status={_status}";
            var customer = _customerId == 0 ? string.Empty : $"&customerId={_customerId}";
            var convertible = string.IsNullOrWhiteSpace(_onlyConvertible) ? string.Empty : "&onlyConvertible=true";
            _result = (await Api.GetAsync<AppResult<PagedResult<QuoteListItemDto>>>($"api/commerce/quotes?search={Uri.EscapeDataString(_search ?? string.Empty)}{status}{customer}{convertible}&page={_page}&pageSize={PageSize}"))?.Data;
            _result ??= new PagedResult<QuoteListItemDto>(new List<QuoteListItemDto>(), 0, _page, PageSize);
        }
        catch (ApiClient.ApiClientException ex)
        {
            _loadError = ex.Message;
            Telemetry.Track("quotes", "load", "error", ex.Message);
            _result = new PagedResult<QuoteListItemDto>(new List<QuoteListItemDto>(), 0, _page, PageSize);
        }
        _loaded = true;
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await Search();
    }

    private async Task Search()
    {
        _page = 1;
        await Load();
        Telemetry.Track("quotes", "search", "success");
    }

    private async Task ClearFilters()
    {
        _search = string.Empty;
        _status = string.Empty;
        _onlyConvertible = string.Empty;
        _customerId = 0;
        _page = 1;
        await Load();
        Telemetry.Track("quotes", "clear-filters", "success");
    }

    private void PrepareNewForm()
    {
        _error = null;
        _success = null;
        _form = new QuoteUpsertCommand
        {
            Status = QuoteStatus.Draft,
            IssuedAtUtc = DateTime.UtcNow,
            Items = new List<CommercialLineFormModel>
            {
                new() { Quantity = 1 }
            }
        };
        _issuedAtDate = DateTime.UtcNow.Date;
        _validUntilDate = null;
        _quickSearch = string.Empty;
        _editingNumber = "borrador";
        _showForm = true;
        MarkClean();
    }

    private void NewItem()
    {
        _error = null;
        _success = null;
        Navigation.NavigateTo("/quotes/new");
    }

    private void Edit(int id)
        => Navigation.NavigateTo($"/quotes/edit/{id}");

    private async Task LoadEditor(int id)
    {
        _error = null;
        _success = null;
        try
        {
            var detail = (await Api.GetAsync<AppResult<QuoteDetailDto>>($"api/commerce/quotes/{id}"))?.Data;
            if (detail is null) return;
            _form = new QuoteUpsertCommand
            {
                Id = detail.Id,
                CustomerId = detail.CustomerId,
                Status = detail.Status,
                IssuedAtUtc = detail.IssuedAtUtc,
                ValidUntilUtc = detail.ValidUntilUtc,
                Observations = detail.Observations,
                Items = detail.Items.Select(x => new CommercialLineFormModel
                {
                    ProductId = x.ProductId,
                    ProductVariantId = x.ProductVariantId,
                    Description = x.Description,
                    InternalCode = x.InternalCode,
                    Quantity = x.Quantity,
                    UnitPrice = x.UnitPrice
                }).ToList()
            };
            _issuedAtDate = detail.IssuedAtUtc;
            _validUntilDate = detail.ValidUntilUtc;
            _editingNumber = detail.Number;
            _showForm = true;
            MarkClean();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Save()
    {
        _error = null;
        _success = null;
        var validation = ValidateEditor();
        if (validation.Count > 0)
        {
            _error = string.Join(" ", validation);
            Telemetry.Track("quotes", "validate", "error", string.Join(" | ", validation));
            return;
        }
        _saving = true;
        try
        {
            _form.IssuedAtUtc = _issuedAtDate;
            _form.ValidUntilUtc = _validUntilDate;
            var body = new
            {
                _form.Id,
                _form.CustomerId,
                _form.Status,
                _form.IssuedAtUtc,
                _form.ValidUntilUtc,
                _form.Observations,
                Items = _form.Items.Select((x, idx) => new { x.ProductId, x.ProductVariantId, x.Description, x.Quantity, x.UnitPrice, SortOrder = idx + 1 }).ToList()
            };

            if (_form.Id == 0)
                await Api.PostAsync("api/commerce/quotes", body);
            else
                await Api.PutAsync($"api/commerce/quotes/{_form.Id}", body);

            _showForm = false;
            _success = "Presupuesto guardado correctamente.";
            Telemetry.Track("quotes", "save", "success", _form.Id == 0 ? "create" : "update");
            Navigation.NavigateTo("/quotes");
        }
        catch (ApiClient.ApiClientException ex)
        {
            Telemetry.Track("quotes", "save", "error", ex.Message);
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Convert(int id)
    {
        _error = null;
        _success = null;
        try
        {
            var result = await Api.PostAsync<object, AppResult<int>>($"api/commerce/quotes/{id}/convert-to-sale", new { quoteId = id, saleStatus = SaleStatus.Draft, issuedAtUtc = DateTime.UtcNow, observations = (string?)null });
            if (result?.Success == true && result.Data is > 0)
            {
                _success = "Presupuesto convertido correctamente.";
                Telemetry.Track("quotes", "convert", "success", $"saleId={result.Data}");
                await Load();
                Navigation.NavigateTo($"/sales/{result.Data}");
            }
            else
            {
                Telemetry.Track("quotes", "convert", "error", result?.Message);
                _error = result?.Message ?? "No se pudo convertir el presupuesto.";
            }
        }
        catch (ApiClient.ApiClientException ex)
        {
            Telemetry.Track("quotes", "convert", "error", ex.Message);
            _error = ex.Message;
        }
    }

    private void AddBlankLine() => _form.Items.Add(new CommercialLineFormModel { Quantity = 1 });

    private void AddSku(CommercialSkuLookupDto sku)
    {
        _form.Items.Add(new CommercialLineFormModel
        {
            ProductId = sku.ProductId,
            ProductVariantId = sku.ProductVariantId,
            Description = sku.Label,
            InternalCode = sku.InternalCode,
            Quantity = 1,
            UnitPrice = sku.SalePrice
        });
        _quickSearch = string.Empty;
    }

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < _form.Items.Count)
            _form.Items.RemoveAt(index);
    }

    private async Task Cancel()
    {
        if (!await ConfirmDiscardIfDirtyAsync())
            return;
        _showForm = false;
        Navigation.NavigateTo("/quotes");
    }
    private void OpenDetail(int id) => Navigation.NavigateTo($"/quotes/{id}");
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }


    private static string QuoteStatusLabel(QuoteStatus status) => status switch
    {
        QuoteStatus.Draft => "Borrador",
        QuoteStatus.Sent => "Enviado",
        QuoteStatus.Approved => "Aprobado",
        QuoteStatus.Rejected => "Rechazado",
        QuoteStatus.Expired => "Vencido",
        QuoteStatus.Converted => "Convertido",
        _ => status.ToString()
    };

    private static string QuoteStatusClass(QuoteStatus status) => status switch
    {
        QuoteStatus.Approved => "ui-badge ui-badge-success",
        QuoteStatus.Converted => "ui-badge ui-badge-primary",
        QuoteStatus.Rejected => "ui-badge ui-badge-danger",
        QuoteStatus.Expired => "ui-badge ui-badge-warning",
        QuoteStatus.Sent => "ui-badge ui-badge-neutral",
        _ => "ui-badge ui-badge-neutral"
    };

}
