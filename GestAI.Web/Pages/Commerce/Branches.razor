@page "/branches"
@page "/branches/new"
@page "/branches/edit/{EditId:int}"
@using Microsoft.AspNetCore.Components.Routing
@using GestAI.Web.Dtos
@using GestAI.Web.Service
@inject ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ProductTelemetryService Telemetry
@inject UnsavedChangesGuardService Guard
@inject CommerceMasterUiService Ui

<PageTitle>Sucursales</PageTitle>

<ListPageHeader Title="Sucursales" Subtitle="Organizá las sucursales del negocio y controlá su estado operativo.">
    <MetaContent>
        @if (IsEditorRoute)
        {
            <button class="btn btn-outline-secondary" @onclick="BackToList"><i class="bi bi-arrow-left me-2"></i>Volver al listado</button>
        }
        else
        {
            <span class="page-hero-chip"><i class="bi bi-shop"></i> @(_result?.TotalCount ?? 0) sucursales</span>
            <button class="btn btn-primary" @onclick="NewItem"><i class="bi bi-plus-circle me-2"></i>Nueva sucursal</button>
        }
    </MetaContent>
</ListPageHeader>

@if (!_loaded)
{
    <div class="card"><div class="card-body">Cargando sucursales...</div></div>
}
else if (IsEditorRoute)
{
    <NavigationLock ConfirmExternalNavigation="@_isDirty" OnBeforeInternalNavigation="@ConfirmInternalNavigation" />
    <div class="card ui-form-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Editor</div>
                    <h5 class="ui-card-title">@(_form.Id == 0 ? "Nueva sucursal" : "Editar sucursal")</h5>
                    <div class="ui-card-subtitle">Completá los datos básicos de la sucursal.</div>
                </div>
            </div>
            <FormFeedback Error="@_error" Success="@_success" />
            <OperationalStateHint IsLoading="@(!_loaded)" HasError="@(!string.IsNullOrWhiteSpace(_error))" IsSaving="@_saving" IsDirty="@_isDirty" />

            <div class="row g-3">
                <div class="col-md-8"><label class="form-label">Nombre</label><input class="form-control" @bind="_form.Name" @bind:after="MarkDirty" /></div>
                <div class="col-md-4"><label class="form-label">Código</label><input class="form-control" @bind="_form.Code" @bind:after="MarkDirty" /></div>
                <div class="col-md-6"><label class="form-label d-block">Estado</label><div class="ui-toggle-field"><input type="checkbox" class="form-check-input" @bind="_form.IsActive" @bind:after="MarkDirty" /><span>@(_form.IsActive ? "Sucursal activa" : "Sucursal inactiva")</span></div></div>
            </div>
            <div class="ui-action-bar">
                <div class="ui-inline-actions">
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">Guardar</button>
                    <button class="btn btn-outline-secondary" @onclick="BackToList">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
}
else if (_result?.Items.Count == 0)
{
    <FormFeedback Error="@_error" Success="@_success" />
    <EmptyState Title="No hay sucursales para mostrar"
                Description="Creá la primera sucursal para empezar a organizar la operación."
                Icon="bi-shop">
        <button class="btn btn-primary" @onclick="NewItem">Crear sucursal</button>
    </EmptyState>
}
else
{
    <FormFeedback Error="@_error" Success="@_success" />
    <ListPageFilters>
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Buscar</label><input class="form-control" @bind="_search" placeholder="Nombre o código" /></div>
            <div class="col-12 col-md-6 col-lg-2"><label class="form-label">Estado</label><select class="form-select" @bind="_status"><option value="">Todos</option><option value="true">Activos</option><option value="false">Inactivos</option></select></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-primary w-100" @onclick="Search">Buscar</button></div>
            <div class="col-12 col-md-6 col-lg-2"><button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Limpiar</button></div>
        </div>
    </ListPageFilters>

    <div class="card ui-data-card">
        <div class="card-body">
            <div class="ui-card-header">
                <div>
                    <div class="ui-card-eyebrow">Estructura comercial</div>
                    <h5 class="ui-card-title">Listado de sucursales</h5>
                    <div class="ui-card-subtitle">Nombre, código interno y depósitos asociados.</div>
                </div>
            </div>
            <UnifiedGrid ActionsDropdown="true">
                <thead><tr><th>Nombre</th><th>Código</th><th>Depósitos</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in _result!.Items)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td>@item.Code</td>
                        <td>@item.WarehousesCount</td>
                        <td><StatusBadge IsActive="@item.IsActive" /></td>
                        <td class="text-end">
                            <div class="dropdown dropstart table-actions">
                                <button class="ui-kebab-trigger" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Acciones">
                                    <i class="bi bi-three-dots-vertical"></i>
                                    <span class="visually-hidden">Acciones</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end ui-actions-menu">
                                    <li><button class="dropdown-item" type="button" @onclick="() => Edit(item)"><i class="bi bi-pencil-square me-2"></i>Editar</button></li>
                                    <li><button class="dropdown-item" type="button" @onclick="() => Toggle(item)"><i class="@($"bi {(item.IsActive ? "bi-toggle-off" : "bi-toggle-on")} me-2")"></i>@(item.IsActive ? "Desactivar" : "Activar")</button></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </UnifiedGrid>
            <ListPaginationBar Page="@_page" TotalPages="@TotalPages" OnPrevious="PrevPage" OnNext="NextPage" />
        </div>
    </div>
}

@code {
    [Parameter] public int? EditId { get; set; }

    private PagedResult<BranchListItemDto>? _result;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private bool _loaded;
    private bool _saving;
    private bool _isDirty;
    private int _page = 1;
    private const int PageSize = 10;
    private BranchUpsertCommand _form = new();
    private string? _error;
    private string? _success;

    private bool IsNewRoute => Nav.Uri.EndsWith("/branches/new", StringComparison.OrdinalIgnoreCase);
    private bool IsEditorRoute => IsNewRoute || EditId.HasValue;
    private int TotalPages => _result is null || _result.TotalCount == 0 ? 1 : (int)Math.Ceiling(_result.TotalCount / (double)_result.PageSize);

    protected override async Task OnParametersSetAsync()
    {
        _loaded = false;

        if (IsEditorRoute)
            await LoadEditor();
        else
            await Load();

        _loaded = true;
    }

    private async Task Search()
    {
        _page = 1;
        await Load();
        Telemetry.Track("branches", "search", "success");
    }

    private async Task ClearFilters()
    {
        _search = string.Empty;
        _status = string.Empty;
        _page = 1;
        await Load();
        Telemetry.Track("branches", "clear-filters", "success");
    }

    private async Task Load()
    {
        try
        {
            _error = null;
            var isActive = string.IsNullOrWhiteSpace(_status) ? string.Empty : $"&isActive={_status}";
            _result = (await Api.GetAsync<AppResult<PagedResult<BranchListItemDto>>>($"api/commerce/branches?search={Uri.EscapeDataString(_search ?? string.Empty)}{isActive}&page={_page}&pageSize={PageSize}"))?.Data;
            Telemetry.Track("branches", "load", "success");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("branches", "load", "error", ex.Message);
            _result = new PagedResult<BranchListItemDto>(new List<BranchListItemDto>(), 0, _page, PageSize);
        }
    }

    private async Task LoadEditor()
    {
        if (IsNewRoute)
        {
            _error = null;
            _success = null;
            _form = new BranchUpsertCommand { IsActive = true };
            _isDirty = false;
            return;
        }

        if (!EditId.HasValue)
        {
            BackToList();
            return;
        }

        try
        {
            _error = null;
            _success = null;
            var detail = (await Api.GetAsync<AppResult<BranchDetailDto>>($"api/commerce/branches/{EditId.Value}"))?.Data;
            if (detail is null)
            {
                BackToList();
                return;
            }

            _form = new BranchUpsertCommand { Id = detail.Id, Name = detail.Name, Code = detail.Code, IsActive = detail.IsActive };
            _isDirty = false;
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
        }
    }

    private void NewItem() => Nav.NavigateTo("/branches/new");

    private void Edit(BranchListItemDto item) => Nav.NavigateTo($"/branches/edit/{item.Id}");

    private async Task Save()
    {
        _error = ValidateEditor();
        if (!string.IsNullOrWhiteSpace(_error))
            return;

        _saving = true;
        try
        {
            if (_form.Id == 0) await Api.PostAsync("api/commerce/branches", new { _form.Name, _form.Code, _form.IsActive });
            else await Api.PutAsync($"api/commerce/branches/{_form.Id}", new { _form.Id, _form.Name, _form.Code, _form.IsActive });

            _isDirty = false;
            _success = Ui.SaveMessage("Sucursal", _form.Id == 0);
            Telemetry.Track("branches", "save", "success", _form.Id == 0 ? "create" : "update");
            BackToList();
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("branches", "save", "error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Toggle(BranchListItemDto item)
    {
        try
        {
            _error = null;
            _success = null;
            await Api.PostAsync($"api/commerce/branches/{item.Id}/status", new { isActive = !item.IsActive });
            _success = Ui.ToggleMessage("Sucursal", item.IsActive);
            await Load();
            Telemetry.Track("branches", "toggle", "success", $"id={item.Id}");
        }
        catch (ApiClient.ApiClientException ex)
        {
            _error = ex.Message;
            Telemetry.Track("branches", "toggle", "error", ex.Message);
        }
    }

    private void BackToList()
    {
        _isDirty = false;
        Nav.NavigateTo("/branches");
    }
    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Load(); } }

    private string? ValidateEditor()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
            return "El nombre de la sucursal es obligatorio.";
        if (_form.Name.Length > 120)
            return "El nombre no puede superar los 120 caracteres.";
        if (!string.IsNullOrWhiteSpace(_form.Code) && _form.Code.Length > 32)
            return "El código no puede superar los 32 caracteres.";
        return null;
    }

    private void MarkDirty() => _isDirty = true;

    private async Task ConfirmInternalNavigation(LocationChangingContext context)
    {
        var leave = await Guard.ConfirmDiscardAsync(JS, _isDirty, _saving, "Tenés cambios sin guardar. ¿Querés salir igual?");
        if (!leave)
            context.PreventNavigation();
    }
}
