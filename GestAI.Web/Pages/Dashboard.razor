@page "/dashboard"
@inject ApiClient Api
@using GestAI.Web.Dtos

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (_summary is null)
{
    <p>Cargando...</p>
}
else
{
    <div class="row g-3">
        <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><h6>Cuenta</h6><strong>@_summary.Name</strong></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><h6>Plan actual</h6><strong>@_summary.PlanName</strong></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><h6>Usuarios</h6><strong>@_summary.CurrentUsers / @_summary.MaxUsers</strong></div></div></div>
        <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><h6>Suscripción</h6><strong>@_summary.PlanStatus</strong></div></div></div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h5>Límites del plan</h5>
            <ul>
                <li>Máximo espacios/tenants: @_summary.MaxProperties</li>
                <li>Máximo entidades: @_summary.MaxUnits</li>
                <li>Máximo usuarios: @_summary.MaxUsers</li>
            </ul>
        </div>
    </div>
}

@code {
    private AccountSummaryDto? _summary;
    protected override async Task OnInitializedAsync()
    {
        _summary = (await Api.GetAsync<AppResult<AccountSummaryDto>>("api/saas/account/summary"))?.Data;
    }
}
