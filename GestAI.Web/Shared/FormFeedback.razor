@if (ValidationErrors is { Count: > 0 })
{
    <div class="alert alert-warning" role="alert">
        <div class="fw-semibold mb-1">Revisá estos datos antes de continuar:</div>
        <ul class="mb-0 ps-3">
            @foreach (var item in ValidationErrors)
            {
                <li>@item</li>
            }
        </ul>
    </div>
}
else if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger" role="alert">@Error</div>
}
else if (!string.IsNullOrWhiteSpace(Success))
{
    <div class="alert alert-success" role="alert">@Success</div>
}

@code {
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Success { get; set; }
    [Parameter] public IReadOnlyList<string>? ValidationErrors { get; set; }
}
