<section class="page-hero ui-list-page-header">
    <div class="ui-list-page-header-main">
        <div class="page-hero-title">@Title</div>
        <div class="page-hero-subtitle">@Subtitle</div>
    </div>
    <div class="page-hero-meta ui-list-page-header-meta">
        @if (MetaContent is not null)
        {
            @MetaContent
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(ChipText))
            {
                <span class="page-hero-chip"><i class="@ChipIconClass"></i> @ChipText</span>
            }

            @Actions
        }
    </div>
</section>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string? ChipText { get; set; }
    [Parameter] public string ChipIconClass { get; set; } = "bi bi-table";
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? MetaContent { get; set; }
}
