*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.mdf
*.ldf

################################################################################
# Config / Secretos
################################################################################
# Archivos locales (no compartidos)
*.local.json
*.*.local.json
appsettings.Local.json
appsettings.*.Local.json

# User secrets están fuera del repo por defecto, no hace falta ignorarlos.
# Si querés ignorar appsettings de dev, descomentá:
# appsettings.Development.json

